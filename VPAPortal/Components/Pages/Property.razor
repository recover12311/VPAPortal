    private async Task AddLog(string level, string action, string itemName, string details)
    {
        Db.PropertyLogs.Add(new PropertyLog
        {
            CompanyId = selectedCompanyId,
            CrewId = level == "Екіпаж" ? selectedCrewId : null,
            Level = level,
            Action = action,
            ItemName = itemName,
            Details = details,
            CreatedBy = currentUser,
            CreatedAt = DateTime.Now
        });
        await Db.SaveChangesAsync();
    }

    private void ToggleLog() => showLog = !showLog;

    private string GetActionBadge(string action) => action switch
    {
        "Додано" => "bg-success",
        "Змінено" => "bg-warning text-dark",
        "Видалено" => "bg-danger",
        "Передано" => "bg-info",
        _ => "bg-secondary"
    };

