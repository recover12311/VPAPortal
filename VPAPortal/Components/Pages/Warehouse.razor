    private void OnInvoiceFileSelected(InputFileChangeEventArgs e)
    {
        invoiceFile = e.File;
    }

    private async Task AddInvoice()
    {
        invoiceMessage = "";

        if (string.IsNullOrWhiteSpace(newInvoiceNumber))
        {
            invoiceMessage = "Введіть номер накладної.";
            invoiceSuccess = false;
            return;
        }

        // Зберігаємо файл на диск, якщо він є
        string? photoPath = null;

        if (invoiceFile != null)
        {
            var uploadsDir = Path.Combine(Env.WebRootPath, "uploads", "invoices");
            Directory.CreateDirectory(uploadsDir);

            var ext      = Path.GetExtension(invoiceFile.Name);
            var fileName = $"{Guid.NewGuid()}{ext}";
            var filePath = Path.Combine(uploadsDir, fileName);

            await using var fs = new FileStream(filePath, FileMode.Create);
            await invoiceFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fs);

            photoPath = $"/uploads/invoices/{fileName}";
        }

        await WarehouseService.AddInvoiceAsync(
            selectedCompanyId, newInvoiceNumber, newInvoiceDate, photoPath, currentUser);

        invoiceMessage = "Накладну додано.";
        invoiceSuccess = true;

        // Скидаємо форму
        newInvoiceNumber = "";
        newInvoiceDate   = DateOnly.FromDateTime(DateTime.Today);
        invoiceFile      = null;

        await LoadCompanyData();
    }

    private async Task DeleteInvoice(int id)
    {
        await WarehouseService.DeleteInvoiceAsync(id, Env.WebRootPath);
        await LoadCompanyData();
    }

    // ════════════════════════════════════════════════════════════════════════
    // ФІЛЬТРИ НАКЛАДНИХ
    // ════════════════════════════════════════════════════════════════════════
    private void ApplyInvoiceFilter()
    {
        var q = allInvoices.AsEnumerable();

        if (!string.IsNullOrEmpty(invoiceFilterNumber))
        {
            q = q.Where(i => i.InvoiceNumber.Contains(
                invoiceFilterNumber, StringComparison.OrdinalIgnoreCase));
        }

        if (invoiceFilterFrom.HasValue)
            q = q.Where(i => i.Date >= invoiceFilterFrom.Value);

        if (invoiceFilterTo.HasValue)
            q = q.Where(i => i.Date <= invoiceFilterTo.Value);

        q = invoiceSortField == "number"
            ? (invoiceSortDesc
                ? q.OrderByDescending(i => i.InvoiceNumber)
                : q.OrderBy(i => i.InvoiceNumber))
            : (invoiceSortDesc
                ? q.OrderByDescending(i => i.Date)
                : q.OrderBy(i => i.Date));

        filteredInvoices = q.ToList();
        invoicePage      = 1;

        UpdatePagedInvoices();
    }

    private void ResetInvoiceFilter()
    {
        invoiceFilterNumber = "";
        invoiceFilterFrom   = null;
        invoiceFilterTo     = null;

        ApplyInvoiceFilter();
    }

    private void SortInvoices(string field)
    {
        if (invoiceSortField == field)
            invoiceSortDesc = !invoiceSortDesc;
        else
        {
            invoiceSortField = field;
            invoiceSortDesc  = true;
        }

        ApplyInvoiceFilter();
    }

    private string InvoiceSortIcon(string field) =>
        invoiceSortField != field ? "" : (invoiceSortDesc ? " ↓" : " ↑");

    private void UpdatePagedInvoices()
    {
        pagedInvoices = filteredInvoices
            .Skip((invoicePage - 1) * invoicePageSize)
            .Take(invoicePageSize)
            .ToList();
    }

    // ════════════════════════════════════════════════════════════════════════
    // ФІЛЬТРИ ЖУРНАЛУ
    // ════════════════════════════════════════════════════════════════════════
    private void ApplyLogFilter()
    {
        var q = allLogs.AsEnumerable();

        if (!string.IsNullOrEmpty(logFilterType))
            q = q.Where(l => l.ItemType == logFilterType);

        if (logFilterFrom.HasValue)
            q = q.Where(l => DateOnly.FromDateTime(l.ChangedAt) >= logFilterFrom.Value);

        if (logFilterTo.HasValue)
            q = q.Where(l => DateOnly.FromDateTime(l.ChangedAt) <= logFilterTo.Value);

        q = logSortDesc
            ? q.OrderByDescending(l => l.ChangedAt)
            : q.OrderBy(l => l.ChangedAt);

        filteredLogs = q.ToList();
        logPage      = 1;

        UpdatePagedLogs();
    }

    private void ResetLogFilter()
    {
        logFilterFrom = null;
        logFilterTo   = null;
        logFilterType = "";

        ApplyLogFilter();
    }

    private void SortLogs(string field)
    {
        logSortDesc = !logSortDesc;
        ApplyLogFilter();
    }

    private string LogSortIcon(string field) => logSortDesc ? " ↓" : " ↑";

    private void UpdatePagedLogs()
    {
        pagedLogs = filteredLogs
            .Skip((logPage - 1) * logPageSize)
            .Take(logPageSize)
            .ToList();
    }

    private string GetLogActionBadge(string action) => action switch
    {
        "Додано"  => "bg-success",
        "Змінено" => "bg-warning text-dark",
        "Видалено"=> "bg-danger",
        _         => "bg-secondary"
    };

    // ════════════════════════════════════════════════════════════════════════
    // ПАГІНАЦІЯ (хелпер)
    // ════════════════════════════════════════════════════════════════════════
    private RenderFragment RenderPagination(
        int page,
        int total,
        Action<int> onPageChange,
        int count) => builder =>
    {
        if (total <= 1) return;

        builder.OpenElement(0, "nav");
        builder.OpenElement(1, "ul");
        builder.AddAttribute(2, "class", "pagination mt-2");

        void AddItem(int seq, int p, string label, bool disabled, bool active)
        {
            builder.OpenElement(seq, "li");
            builder.AddAttribute(seq + 1, "class",
                $"page-item {(disabled ? "disabled" : "")} {(active ? "active" : "")}");
            builder.OpenElement(seq + 2, "button");
            builder.AddAttribute(seq + 3, "class", "page-link");
            builder.AddAttribute(seq + 4, "onclick",
                EventCallback.Factory.Create(this, () => onPageChange(p)));
            builder.AddContent(seq + 5, label);
            builder.CloseElement();
            builder.CloseElement();
        }

        AddItem(10, page - 1, "‹", page == 1, false);

        for (int i = 1; i <= total; i++)
            AddItem(20 + i * 10, i, i.ToString(), false, i == page);

        AddItem(200, page + 1, "›", page == total, false);

        builder.CloseElement();
        builder.OpenElement(300, "p");
        builder.AddAttribute(301, "class", "text-muted small");
        builder.AddContent(302, $"Всього записів: {count}. Сторінка {page} з {total}.");
        builder.CloseElement();
        builder.CloseElement();
    };
