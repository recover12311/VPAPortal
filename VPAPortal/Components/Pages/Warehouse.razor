    private async Task DeleteCompany()
    {
        await WarehouseService.DeleteCompanyAsync(deletingCompanyId);

        showDeleteCompanyConfirm = false;
        selectedCompanyId = 0;

        companies = await WarehouseService.GetCompaniesAsync();

        if (companies.Any())
        {
            selectedCompanyId = companies.First().Id;
            await LoadCompanyData();
        }
        else
        {
            selectedCompany = null;
        }
    }

