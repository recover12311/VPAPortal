@page "/warehouse"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using VPAPortal.Data
@using VPAPortal.Data.Models
@attribute [Authorize]
@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject IWebHostEnvironment Env

<PageTitle>Склад</PageTitle>

<h3 class="mb-4">Склад</h3>

@if (companies == null)
{
    <p>Завантаження...</p>
}
else
{
    @* ===== ВКЛАДКИ РОТ ===== *@
    <div class="d-flex align-items-center flex-wrap gap-2 mb-4">
        <ul class="nav nav-tabs flex-nowrap mb-0" style="border-bottom:none;">
            @foreach (var company in companies)
            {
                var cId = company.Id;
                <li class="nav-item">
                    <button class="nav-link @(selectedCompanyId == cId ? "active" : "")"
                            @onclick="() => SelectCompany(cId)">
                        @company.Name
                    </button>
                </li>
            }
        </ul>
        <AuthorizeView Roles="SuperAdmin,Moderator">
            <Authorized>
                @if (!showAddCompanyForm)
                {
                    <button class="btn btn-sm btn-outline-success ms-2"
                            @onclick="() => showAddCompanyForm = true">
                        + Рота
                    </button>
                }
                else
                {
                    <div class="d-flex gap-2 align-items-center ms-2">
                        <input class="form-control form-control-sm" style="width:150px;"
                               @bind="newCompanyName" placeholder="Назва роти" />
                        <button class="btn btn-sm btn-success" @onclick="AddCompany">Додати</button>
                        <button class="btn btn-sm btn-secondary"
                                @onclick="() => showAddCompanyForm = false">
                            ✕
                        </button>
                    </div>
                }
            </Authorized>
        </AuthorizeView>
    </div>

    @if (selectedCompany != null)
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">@selectedCompany.Name</h5>
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <button class="btn btn-sm btn-outline-danger"
                            @onclick="() => ShowDeleteCompanyConfirm(selectedCompany.Id, selectedCompany.Name)">
                        🗑 Видалити роту
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>

        @if (showDeleteCompanyConfirm)
        {
            <div class="alert alert-danger d-flex align-items-center gap-3 mb-3">
                <span>Видалити <strong>@deletingCompanyName</strong> та всі її дані?</span>
                <button class="btn btn-sm btn-danger" @onclick="DeleteCompany">Так, видалити</button>
                <button class="btn btn-sm btn-secondary"
                        @onclick="() => showDeleteCompanyConfirm = false">
                    Скасувати
                </button>
            </div>
        }

        @* ===== ЗАПАСИ ===== *@
        <div class="row g-4 align-items-start mb-4">

            @* БЕЗПІЛОТНИКИ *@
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header fw-bold">🚁 Безпілотники</div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Назва</th>
                                    <th style="width:110px;">Кількість</th>
                                    <AuthorizeView Roles="SuperAdmin,Moderator">
                                        <Authorized><th style="width:80px;">Дії</th></Authorized>
                                    </AuthorizeView>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in wDrones)
                                {
                                    var itemId = item.Id;
                                    <tr>
                                        <td>
                                            @if (editingWDroneId == itemId)
                                            {
                                                <input class="form-control form-control-sm"
                                                       @bind="editingWDroneName" />
                                            }
                                            else
                                            {

                                                @item.Name
                                            }
                                        </td>
                                        <td>
                                            @if (editingWDroneId == itemId)
                                            {
                                                <input class="form-control form-control-sm"
                                                       type="number" min="0"
                                                       @bind="editingWDroneQty" />
                                            }
                                            else
                                            {
                                                <span class="badge @(item.Quantity > 0 ? "bg-success" : "bg-secondary")">
                                                    @item.Quantity
                                                </span>
                                            }
                                        </td>
                                        <AuthorizeView Roles="SuperAdmin,Moderator">
                                            <Authorized>
                                                <td>
                                                    @if (editingWDroneId == itemId)
                                                    {
                                                        <button class="btn btn-xs btn-success me-1"
                                                                @onclick="() => SaveWDrone(itemId)">
                                                            ✓
                                                        </button>
                                                        <button class="btn btn-xs btn-secondary"
                                                                @onclick="() => editingWDroneId = 0">
                                                            ✕
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-xs btn-warning me-1"
                                                                @onclick="() => StartWDroneEdit(item)">
                                                            ✎
                                                        </button>
                                                        <button class="btn btn-xs btn-danger"
                                                                @onclick="() => DeleteWDrone(itemId)">
                                                            🗑
                                                        </button>
                                                    }
                                                </td>
                                            </Authorized>
                                        </AuthorizeView>
                                    </tr>
                                }
                                @if (!wDrones.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-muted text-center py-2">
                                            Немає позицій
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <AuthorizeView Roles="SuperAdmin,Moderator">
                        <Authorized>
                            <div class="card-footer">
                                @if (showAddWDroneForm)
                                {
                                    <div class="d-flex gap-2">
                                        <input class="form-control form-control-sm"
                                               @bind="newWDroneName" placeholder="Назва" />
                                        <input class="form-control form-control-sm" type="number"
                                               min="0" @bind="newWDroneQty" style="width:80px;" />
                                        <button class="btn btn-sm btn-success"
                                                @onclick="AddWDrone">
                                            +
                                        </button>
                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="() => showAddWDroneForm = false">
                                            ✕
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-primary w-100"
                                            @onclick="() => showAddWDroneForm = true">
                                        + Додати безпілотник
                                    </button>
                                }
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>

            @* БОЄКОМПЛЕКТ *@
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header fw-bold">💣 Боєкомплект</div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Назва</th>
                                    <th style="width:110px;">Кількість</th>
                                    <AuthorizeView Roles="SuperAdmin,Moderator">
                                        <Authorized><th style="width:80px;">Дії</th></Authorized>
                                    </AuthorizeView>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in wAmmos)
                                {
                                    var itemId = item.Id;
                                    <tr>
                                        <td>
                                            @if (editingWAmmoId == itemId)
                                            {
                                                <input class="form-control form-control-sm"
                                                       @bind="editingWAmmoName" />
                                            }
                                            else
                                            {

                                                @item.Name
                                            }
                                        </td>
                                        <td>
                                            @if (editingWAmmoId == itemId)
                                            {
                                                <input class="form-control form-control-sm"
                                                       type="number" min="0"
                                                       @bind="editingWAmmoQty" />
                                            }
                                            else
                                            {
                                                <span class="badge @(item.Quantity > 0 ? "bg-success" : "bg-secondary")">
                                                    @item.Quantity
                                                </span>
                                            }
                                        </td>
                                        <AuthorizeView Roles="SuperAdmin,Moderator">
                                            <Authorized>
                                                <td>
                                                    @if (editingWAmmoId == itemId)
                                                    {
                                                        <button class="btn btn-xs btn-success me-1"
                                                                @onclick="() => SaveWAmmo(itemId)">
                                                            ✓
                                                        </button>
                                                        <button class="btn btn-xs btn-secondary"
                                                                @onclick="() => editingWAmmoId = 0">
                                                            ✕
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-xs btn-warning me-1"
                                                                @onclick="() => StartWAmmoEdit(item)">
                                                            ✎
                                                        </button>
                                                        <button class="btn btn-xs btn-danger"
                                                                @onclick="() => DeleteWAmmo(itemId)">
                                                            🗑
                                                        </button>
                                                    }
                                                </td>
                                            </Authorized>
                                        </AuthorizeView>
                                    </tr>
                                }
                                @if (!wAmmos.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-muted text-center py-2">
                                            Немає позицій
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <AuthorizeView Roles="SuperAdmin,Moderator">
                        <Authorized>
                            <div class="card-footer">
                                @if (showAddWAmmoForm)
                                {
                                    <div class="d-flex gap-2">
                                        <input class="form-control form-control-sm"
                                               @bind="newWAmmoName" placeholder="Назва" />
                                        <input class="form-control form-control-sm" type="number"
                                               min="0" @bind="newWAmmoQty" style="width:80px;" />
                                        <button class="btn btn-sm btn-success"
                                                @onclick="AddWAmmo">
                                            +
                                        </button>
                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="() => showAddWAmmoForm = false">
                                            ✕
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-primary w-100"
                                            @onclick="() => showAddWAmmoForm = true">
                                        + Додати боєкомплект
                                    </button>
                                }
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>

        @* ===== НАКЛАДНІ ===== *@
        <div class="card mb-4">
            <div class="card-header fw-bold">📄 Накладні</div>
            <div class="card-body">
                <AuthorizeView Roles="SuperAdmin,Moderator">
                    <Authorized>
                        <div class="row g-3 mb-3 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label">Номер накладної</label>
                                <input class="form-control" @bind="newInvoiceNumber"
                                       placeholder="Номер" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Дата</label>
                                <input type="date" class="form-control" @bind="newInvoiceDate" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Фото накладної</label>
                                <InputFile OnChange="OnInvoiceFileSelected"
                                           accept="image/*,.pdf" class="form-control" />
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-primary w-100"
                                        @onclick="AddInvoice">
                                    Додати
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(invoiceMessage))
                        {
                            <div class="alert @(invoiceSuccess ? "alert-success" : "alert-danger")">
                                @invoiceMessage
                            </div>
                        }
                    </Authorized>
                </AuthorizeView>

                @* Фільтр накладних *@
                <div class="d-flex gap-2 mb-3 align-items-end flex-wrap">
                    <div>
                        <label class="form-label mb-1 small">Від</label>
                        <input type="date" class="form-control form-control-sm"
                               @bind="invoiceFilterFrom" @bind:after="ApplyInvoiceFilter" />
                    </div>
                    <div>
                        <label class="form-label mb-1 small">До</label>
                        <input type="date" class="form-control form-control-sm"
                               @bind="invoiceFilterTo" @bind:after="ApplyInvoiceFilter" />
                    </div>
                    <div>
                        <label class="form-label mb-1 small">Номер</label>
                        <input class="form-control form-control-sm" style="width:150px;"
                               @bind="invoiceFilterNumber" @bind:after="ApplyInvoiceFilter"
                               placeholder="Пошук..." />
                    </div>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="ResetInvoiceFilter">
                        ✕ Скинути
                    </button>
                </div>

                @if (!filteredInvoices.Any())
                {
                    <p class="text-muted">Накладних немає.</p>
                }
                else
                {
                    <table class="table table-sm table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th @onclick='() => SortInvoices("number")' style="cursor:pointer">
                                    Номер @InvoiceSortIcon("number")
                                </th>
                                <th @onclick='() => SortInvoices("date")' style="cursor:pointer">
                                    Дата @InvoiceSortIcon("date")
                                </th>
                                <th>Файл</th>
                                <th>Додав</th>
                                <AuthorizeView Roles="SuperAdmin,Moderator">
                                    <Authorized><th style="width:60px;">Дії</th></Authorized>
                                </AuthorizeView>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in pagedInvoices)
                            {
                                var invId = inv.Id;
                                <tr>
                                    <td>@inv.InvoiceNumber</td>
                                    <td>@inv.Date.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(inv.PhotoPath))
                                        {
                                            <a href="@inv.PhotoPath" target="_blank"
                                               class="btn btn-xs btn-outline-info">
                                                📎 Переглянути
                                            </a>
                                        }
                                        else
                                        {

                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@inv.CreatedBy</td>
                                    <AuthorizeView Roles="SuperAdmin,Moderator">
                                        <Authorized>
                                            <td>
                                                <button class="btn btn-xs btn-danger"
                                                        @onclick="() => DeleteInvoice(invId)">
                                                    🗑
                                                </button>
                                            </td>
                                        </Authorized>
                                    </AuthorizeView>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @RenderPagination(invoicePage, invoiceTotalPages,
                    (p) => { invoicePage = p; UpdatePagedInvoices(); },
                filteredInvoices.Count)
                }
            </div>
        </div>

        @* ===== ЛОГУВАННЯ ===== *@
        <div class="card">
            <div class="card-header fw-bold">📋 Журнал змін складу</div>
            <div class="card-body">
                <div class="d-flex gap-2 mb-3 align-items-end flex-wrap">
                    <div>
                        <label class="form-label mb-1 small">Від</label>
                        <input type="date" class="form-control form-control-sm"
                               @bind="logFilterFrom" @bind:after="ApplyLogFilter" />
                    </div>
                    <div>
                        <label class="form-label mb-1 small">До</label>
                        <input type="date" class="form-control form-control-sm"
                               @bind="logFilterTo" @bind:after="ApplyLogFilter" />
                    </div>
                    <div>
                        <label class="form-label mb-1 small">Тип</label>
                        <select class="form-select form-select-sm" style="width:160px;"
                                @bind="logFilterType" @bind:after="ApplyLogFilter">
                            <option value="">— всі —</option>
                            <option value="Дрон">Безпілотник</option>
                            <option value="Боєкомплект">Боєкомплект</option>
                        </select>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="ResetLogFilter">
                        ✕ Скинути
                    </button>
                </div>

                @if (!filteredLogs.Any())
                {
                    <p class="text-muted">Записів немає.</p>
                }
                else
                {
                    <table class="table table-sm table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th @onclick='() => SortLogs("date")' style="cursor:pointer">
                                    Дата @LogSortIcon("date")
                                </th>
                                <th>Тип</th>
                                <th>Назва</th>
                                <th>Дія</th>
                                <th>Було</th>
                                <th>Стало</th>
                                <th>Хто</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in pagedLogs)
                            {
                                <tr>
                                    <td>@log.ChangedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@log.ItemType</td>
                                    <td>@log.ItemName</td>
                                    <td>
                                        <span class="badge @GetLogActionBadge(log.Action)">
                                            @log.Action
                                        </span>
                                    </td>
                                    <td>@log.QuantityBefore</td>
                                    <td>@log.QuantityAfter</td>
                                    <td class="text-muted small">@log.ChangedBy</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @RenderPagination(logPage, logTotalPages,
                    (p) => { logPage = p; UpdatePagedLogs(); },
                filteredLogs.Count)
                }
            </div>
        </div>
    }
}

<style>
    .btn-xs {
        padding: 0.1rem 0.4rem;
        font-size: 0.75rem;
    }
</style>

@code {
    private List<Company>? companies;
    private int selectedCompanyId;
    private Company? selectedCompany;
    private string currentUser = "";

    // Роти
    private bool showAddCompanyForm = false;
    private string newCompanyName = "";
    private bool showDeleteCompanyConfirm = false;
    private int deletingCompanyId;
    private string deletingCompanyName = "";

    // Склад — безпілотники
    private List<WarehouseDroneItem> wDrones = new();
    private bool showAddWDroneForm = false;
    private string newWDroneName = "";
    private int newWDroneQty = 0;
    private int editingWDroneId = 0;
    private string editingWDroneName = "";
    private int editingWDroneQty = 0;

    // Склад — боєкомплект
    private List<WarehouseAmmoItem> wAmmos = new();
    private bool showAddWAmmoForm = false;
    private string newWAmmoName = "";
    private int newWAmmoQty = 0;
    private int editingWAmmoId = 0;
    private string editingWAmmoName = "";
    private int editingWAmmoQty = 0;

    // Накладні
    private List<WarehouseInvoice> allInvoices = new();
    private List<WarehouseInvoice> filteredInvoices = new();
    private List<WarehouseInvoice> pagedInvoices = new();
    private string newInvoiceNumber = "";
    private DateOnly newInvoiceDate = DateOnly.FromDateTime(DateTime.Today);
    private IBrowserFile? invoiceFile;
    private string invoiceMessage = "";
    private bool invoiceSuccess = false;
    private int invoicePage = 1;
    private int invoicePageSize = 10;
    private int invoiceTotalPages => (int)Math.Ceiling(filteredInvoices.Count / (double)invoicePageSize);
    private string invoiceFilterNumber = "";
    private DateOnly? invoiceFilterFrom = null;
    private DateOnly? invoiceFilterTo = null;
    private string invoiceSortField = "date";
    private bool invoiceSortDesc = true;

    // Логування
    private List<WarehouseLog> allLogs = new();
    private List<WarehouseLog> filteredLogs = new();
    private List<WarehouseLog> pagedLogs = new();
    private int logPage = 1;
    private int logPageSize = 15;
    private int logTotalPages => (int)Math.Ceiling(filteredLogs.Count / (double)logPageSize);
    private DateOnly? logFilterFrom = null;
    private DateOnly? logFilterTo = null;
    private string logFilterType = "";
    private string logSortField = "date";
    private bool logSortDesc = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = authState.User.Identity?.Name ?? "";

        companies = await Db.Companies.OrderBy(c => c.SortOrder).ToListAsync();
        if (companies.Any())
        {
            selectedCompanyId = companies.First().Id;
            await LoadCompanyData();
        }
    }

    private async Task SelectCompany(int id)
    {
        selectedCompanyId = id;
        editingWDroneId = 0; editingWAmmoId = 0;
        showAddWDroneForm = false; showAddWAmmoForm = false;
        await LoadCompanyData();
    }

    private async Task LoadCompanyData()
    {
        selectedCompany = companies?.FirstOrDefault(c => c.Id == selectedCompanyId);

        wDrones = await Db.WarehouseDroneItems
            .Where(d => d.CompanyId == selectedCompanyId)
            .OrderBy(d => d.Name).ToListAsync();

        wAmmos = await Db.WarehouseAmmoItems
            .Where(a => a.CompanyId == selectedCompanyId)
            .OrderBy(a => a.Name).ToListAsync();

        allInvoices = await Db.WarehouseInvoices
            .Where(i => i.CompanyId == selectedCompanyId)
            .OrderByDescending(i => i.Date).ToListAsync();

        allLogs = await Db.WarehouseLogs
            .Where(l => l.CompanyId == selectedCompanyId)
            .OrderByDescending(l => l.ChangedAt).ToListAsync();

        ApplyInvoiceFilter();
        ApplyLogFilter();
    }

    // ===== РОТИ =====
    private async Task AddCompany()
    {
        if (string.IsNullOrWhiteSpace(newCompanyName)) return;
        var maxOrder = companies!.Any() ? companies.Max(c => c.SortOrder) : 0;
        var company = new Company { Name = newCompanyName.Trim(), SortOrder = maxOrder + 1 };
        Db.Companies.Add(company);
        await Db.SaveChangesAsync();
        newCompanyName = ""; showAddCompanyForm = false;
        companies = await Db.Companies.OrderBy(c => c.SortOrder).ToListAsync();
        selectedCompanyId = company.Id;
        await LoadCompanyData();
    }

    private void ShowDeleteCompanyConfirm(int id, string name)
    {
        deletingCompanyId = id; deletingCompanyName = name;
        showDeleteCompanyConfirm = true;
    }

    private async Task DeleteCompany()
    {
        var company = await Db.Companies.FindAsync(deletingCompanyId);
        if (company != null)
        {
            Db.WarehouseDroneItems.RemoveRange(
                Db.WarehouseDroneItems.Where(d => d.CompanyId == deletingCompanyId));
            Db.WarehouseAmmoItems.RemoveRange(
                Db.WarehouseAmmoItems.Where(a => a.CompanyId == deletingCompanyId));
            Db.WarehouseInvoices.RemoveRange(
                Db.WarehouseInvoices.Where(i => i.CompanyId == deletingCompanyId));
            Db.WarehouseLogs.RemoveRange(
                Db.WarehouseLogs.Where(l => l.CompanyId == deletingCompanyId));
            Db.Companies.Remove(company);
            await Db.SaveChangesAsync();
        }
        showDeleteCompanyConfirm = false;
        selectedCompanyId = 0;
        companies = await Db.Companies.OrderBy(c => c.SortOrder).ToListAsync();
        if (companies.Any())
        {
            selectedCompanyId = companies.First().Id;
            await LoadCompanyData();
        }
        else { selectedCompany = null; }
    }

    // ===== БЕЗПІЛОТНИКИ СКЛАДУ =====
    private async Task AddWDrone()
    {
        if (string.IsNullOrWhiteSpace(newWDroneName)) return;

        var existing = wDrones.FirstOrDefault(d =>
            d.Name.Equals(newWDroneName.Trim(), StringComparison.OrdinalIgnoreCase));

        if (existing != null)
        {
            await AddWarehouseLog("Дрон", existing.Name, existing.Quantity,
                existing.Quantity + newWDroneQty, "Додано");
            existing.Quantity += newWDroneQty;
        }
        else
        {
            var item = new WarehouseDroneItem
            {
                CompanyId = selectedCompanyId,
                Name = newWDroneName.Trim(),
                Quantity = newWDroneQty
            };
