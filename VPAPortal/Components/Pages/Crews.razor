@page "/crews"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using VPAPortal.Business.Services.Interfaces
@using VPAPortal.Common
@using VPAPortal.Data.Models
@using VPAPortal.Data.Services
@attribute [Authorize]
@inject ICrewService CrewService
@inject IWarehouseService WarehouseService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Екіпажі</PageTitle>

<div class="page-title-bar crews">
    <span class="page-icon">👥</span>
    <h3>Екіпажі</h3>
</div>

@if (companies == null)
{
    <p>Завантаження...</p>
}
else
{
    @* ===== ВКЛАДКИ РОТ ===== *@
    <ul class="nav nav-tabs mb-2">
        @foreach (var company in companies)
        {
            var cId = company.Id;
            <li class="nav-item">
                <button class="nav-link @(selectedCompanyId == cId ? "active" : "")"
                        @onclick="() => SelectCompany(cId)">
                    @company.Name
                </button>
            </li>
        }
    </ul>

    @if (selectedCompany != null)
    {
        @* ===== ВКЛАДКИ ЕКІПАЖІВ ===== *@
        <div class="d-flex align-items-center flex-wrap gap-2 mb-4"
             style="border-bottom: 1px solid #dee2e6; padding-bottom: 0;">

            <ul class="nav nav-tabs flex-nowrap mb-0" style="border-bottom:none;">
                @foreach (var crew in crews)
                {
                    var crewId = crew.Id;
                    <li class="nav-item">
                        <button class="nav-link @(selectedCrewId == crewId ? "active" : "")"
                                @onclick="() => SelectCrew(crewId)">
                            @crew.Name
                            <span class="badge @GetCrewTypeBadge(crew.Type) ms-1"
                                  style="font-size:0.65rem;">
                                @crew.Type
                            </span>
                        </button>
                    </li>
                }
            </ul>

            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    @if (!showAddCrewForm)
                    {
                        <button class="btn btn-sm btn-outline-success ms-2"
                                @onclick="() => showAddCrewForm = true">
                            + Екіпаж
                        </button>
                    }
                    else
                    {
                        <div class="d-flex gap-2 align-items-center ms-2">
                            <input class="form-control form-control-sm"
                                   style="width:130px;"
                                   @bind="newCrewName"
                                   placeholder="Назва" />
                            <select class="form-select form-select-sm"
                                    style="width:120px;"
                                    @bind="newCrewType">
                                <option value="@CrewType.FPV">FPV</option>
                                <option value="@CrewType.Бомбер">Бомбер</option>
                                <option value="@CrewType.Крило">Крило</option>
                            </select>
                            <button class="btn btn-sm btn-success" @onclick="AddCrew">
                                Додати
                            </button>
                            <button class="btn btn-sm btn-secondary"
                                    @onclick="() => showAddCrewForm = false">
                                ✕
                            </button>
                        </div>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (selectedCrew != null)
        {
            @* ── Заголовок екіпажу ── *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="mb-0 d-inline">@selectedCrew.Name</h5>
                    <span class="badge @GetCrewTypeBadge(selectedCrew.Type) ms-2">
                        @selectedCrew.Type
                    </span>
                </div>
                <AuthorizeView Roles="SuperAdmin,Moderator">
                    <Authorized>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => ShowDeleteCrewConfirm(selectedCrew.Id, selectedCrew.Name)">
                            🗑 Видалити екіпаж
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>

            @* ── Підтвердження видалення ── *@
            @if (showDeleteCrewConfirm)
            {
                <div class="alert alert-danger d-flex align-items-center gap-3 mb-3">
                    <span>
                        Видалити <strong>@deletingCrewName</strong> та всі його дані?
                    </span>
                    <button class="btn btn-sm btn-danger" @onclick="DeleteCrew">
                        Так, видалити
                    </button>
                    <button class="btn btn-sm btn-secondary"
                            @onclick="() => showDeleteCrewConfirm = false">
                        Скасувати
                    </button>
                </div>
            }

            @* ===== ЗАПАСИ ЕКІПАЖУ ===== *@
            <div class="row g-4 align-items-start mb-4">

                @if (selectedCrew.Type == CrewType.FPV)
                {
                    <div class="col-md-6">
                        @RenderDroneCard("🚁 Безпілотники", drones)
                    </div>
                }

                @if (selectedCrew.Type == CrewType.Бомбер)
                {
                    <div class="col-md-6">
                        @RenderBomberCard()
                    </div>
                }

                @if (selectedCrew.Type == CrewType.Крило)
                {
                    <div class="col-md-6">
                        @RenderWingCard()
                    </div>
                }

                @if (selectedCrew.Type == CrewType.FPV || selectedCrew.Type == CrewType.Бомбер)
                {
                    <div class="col-md-6">
                        @RenderAmmoCard()
                    </div>
                }
            </div>

            @* ===== ПОПОВНЕННЯ ЗІ СКЛАДУ ===== *@
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <div class="card mb-4">
                        <div class="card-header fw-bold">
                            📦 Поповнити зі складу роти (@selectedCompany?.Name)
                        </div>
                        <div class="card-body">
                            <div class="row g-3 align-items-end">

                                <div class="col-md-2">
                                    <label class="form-label">Тип</label>
                                    <select class="form-select"
                                            @bind="transferType"
                                            @bind:after="OnTransferTypeChanged">
                                        @if (selectedCrew.Type == CrewType.FPV)
                                        {
                                            <option value="drone">Безпілотник</option>
                                            <option value="ammo">Боєкомплект</option>
                                        }
                                        else if (selectedCrew.Type == CrewType.Бомбер)
                                        {
                                            <option value="bomber">Бомбер</option>
                                            <option value="ammo">Боєкомплект</option>
                                        }
                                        else if (selectedCrew.Type == CrewType.Крило)
                                        {
                                            <option value="wing">Крило</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label">Назва зі складу</label>
                                    <select class="form-select" @bind="transferItemId">
                                        <option value="0">— оберіть —</option>
                                        @if (transferType is "drone" or "bomber" or "wing")
                                        {
                                            @foreach (var d in warehouseDrones)
                                            {
                                                <option value="@d.Id">
                                                    @d.Name (на складі: @d.Quantity)
                                                </option>
                                            }
                                        }
                                        else
                                        {
                                            @foreach (var a in warehouseAmmos)
                                            {
                                                <option value="@a.Id">
                                                    @a.Name (на складі: @a.Quantity)
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label">Кількість</label>
                                    <input type="number" class="form-control"
                                           min="1" @bind="transferQty" />
                                </div>

                                <div class="col-md-2">
                                    <button class="btn btn-success w-100"
                                            @onclick="TransferFromWarehouse">
                                        Передати екіпажу
                                    </button>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(transferMessage))
                            {
                                <div class="alert @(transferSuccess ? "alert-success" : "alert-danger") mt-3">
                                    @transferMessage
                                </div>
                            }
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>

            @* ===== ЖУРНАЛ ЕКІПАЖУ ===== *@
            <div class="card">
                <div class="card-header fw-bold">📋 Журнал змін екіпажу</div>
                <div class="card-body">

                    <div class="d-flex gap-2 mb-3 align-items-end flex-wrap">
                        <div>
                            <label class="form-label mb-1 small">Від</label>
                            <input type="date" class="form-control form-control-sm"
                                   @bind="crewLogFilterFrom"
                                   @bind:after="ApplyCrewLogFilter" />
                        </div>
                        <div>
                            <label class="form-label mb-1 small">До</label>
                            <input type="date" class="form-control form-control-sm"
                                   @bind="crewLogFilterTo"
                                   @bind:after="ApplyCrewLogFilter" />
                        </div>
                        <div>
                            <label class="form-label mb-1 small">Тип</label>
                            <select class="form-select form-select-sm"
                                    style="width:160px;"
                                    @bind="crewLogFilterType"
                                    @bind:after="ApplyCrewLogFilter">
                                <option value="">— всі —</option>
                                <option value="Дрон">Безпілотник</option>
                                <option value="Боєкомплект">Боєкомплект</option>
                            </select>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="ResetCrewLogFilter">
                            ✕ Скинути
                        </button>
                    </div>

                    @if (!filteredCrewLogs.Any())
                    {
                        <p class="text-muted">Записів немає.</p>
                    }
                    else
                    {
                        <table class="table table-sm table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th style="cursor:pointer" @onclick="SortCrewLogs">
                                        Дата @(crewLogSortDesc ? "↓" : "↑")
                                    </th>
                                    <th>Тип</th>
                                    <th>Назва</th>
                                    <th>Дія</th>
                                    <th>Було</th>
                                    <th>Стало</th>
                                    <th>Хто</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in pagedCrewLogs)
                                {
                                    <tr>
                                        <td>@log.ChangedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@log.ItemType</td>
                                        <td>@log.ItemName</td>
                                        <td>
                                            <span class="badge @GetLogBadge(log.Action)">
                                                @log.Action
                                            </span>
                                        </td>
                                        <td>@log.QuantityBefore</td>
                                        <td>@log.QuantityAfter</td>
                                        <td class="text-muted small">@log.ChangedBy</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        @if (crewLogTotalPages > 1)
                        {
                            <nav>
                                <ul class="pagination mt-2">
                                    <li class="page-item @(crewLogPage == 1 ? "disabled" : "")">
                                        <button class="page-link"
                                                @onclick="() => GoToCrewLogPage(crewLogPage - 1)">
                                            ‹
                                        </button>
                                    </li>
                                    @for (int p = 1; p <= crewLogTotalPages; p++)
                                    {
                                        var pn = p;
                                        <li class="page-item @(crewLogPage == pn ? "active" : "")">
                                            <button class="page-link"
                                                    @onclick="() => GoToCrewLogPage(pn)">
                                                @pn
                                            </button>
                                        </li>
                                    }
                                    <li class="page-item @(crewLogPage == crewLogTotalPages ? "disabled" : "")">
                                        <button class="page-link"
                                                @onclick="() => GoToCrewLogPage(crewLogPage + 1)">
                                            ›
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                            <p class="text-muted small">
                                Всього: @filteredCrewLogs.Count.
                                Сторінка @crewLogPage з @crewLogTotalPages.
                            </p>
                        }
                    }
                </div>
            </div>
        }
    }
}

<style>
    .btn-xs { padding: 0.1rem 0.4rem; font-size: 0.75rem; }
</style>

@code {
    // ── Поточний користувач ─────────────────────────────────────────────────
    private string currentUser = "";

    // ── Роти ────────────────────────────────────────────────────────────────
    private List<Company>? companies;
    private int selectedCompanyId;
    private Company? selectedCompany;

    // ── Екіпажі ─────────────────────────────────────────────────────────────
    private List<Crew> crews = new();
    private int selectedCrewId;
    private Crew? selectedCrew;

    private bool showAddCrewForm = false;
    private string newCrewName = "";
    private CrewType newCrewType = CrewType.FPV;
    private bool showDeleteCrewConfirm = false;
    private int deletingCrewId;
    private string deletingCrewName = "";

    // ── Безпілотники ────────────────────────────────────────────────────────
    private List<DroneItem> drones = new();
    private List<DroneItem> bombers = new();
    private List<DroneItem> wings = new();

    private bool showAddDroneForm = false;
    private string newDroneName = "";
    private int newDroneQty = 0;

    private bool showAddBomberForm = false;
    private string newBomberName = "";
    private int newBomberQty = 0;

    private bool showAddWingForm = false;
    private string newWingName = "";
    private int newWingQty = 0;

    private int editingDroneId = 0;
    private string editingDroneName = "";
    private int editingDroneQty = 0;

    // ── Боєкомплект ─────────────────────────────────────────────────────────
    private List<AmmoItem> ammos = new();
    private bool showAddAmmoForm = false;
    private string newAmmoName = "";
    private int newAmmoQty = 0;
    private int editingAmmoId = 0;
    private string editingAmmoName = "";
    private int editingAmmoQty = 0;

    // ── Передача зі складу ──────────────────────────────────────────────────
    private string transferType = "drone";
    private int transferItemId = 0;
    private int transferQty = 1;
    private string transferMessage = "";
    private bool transferSuccess = false;
    private List<WarehouseDroneItem> warehouseDrones = new();
    private List<WarehouseAmmoItem> warehouseAmmos = new();

    // ── Журнал ──────────────────────────────────────────────────────────────
    private List<CrewLog> allCrewLogs = new();
    private List<CrewLog> filteredCrewLogs = new();
    private List<CrewLog> pagedCrewLogs = new();

    private int crewLogPage = 1;
    private int crewLogPageSize = 15;
    private int crewLogTotalPages =>
        (int)Math.Ceiling(filteredCrewLogs.Count / (double)crewLogPageSize);
    private DateOnly? crewLogFilterFrom = null;
    private DateOnly? crewLogFilterTo = null;
    private string crewLogFilterType = "";
    private bool crewLogSortDesc = true;

    // ════════════════════════════════════════════════════════════════════════
    // RENDER FRAGMENTS
    // ════════════════════════════════════════════════════════════════════════

    /// <summary>Спільна таблиця рядків для будь-якого типу DroneItem.</summary>
    private RenderFragment RenderDroneTable(List<DroneItem> items) => __builder =>
    {
        <table class="table table-sm table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Назва</th>
                    <th style="width:110px;">Кількість</th>
                    <AuthorizeView Roles="SuperAdmin,Moderator">
                        <Authorized><th style="width:80px;">Дії</th></Authorized>
                    </AuthorizeView>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    var itemId = item.Id;
                    <tr>
                        <td>
                            @if (editingDroneId == itemId)
                            {
                                <input class="form-control form-control-sm"
                                       @bind="editingDroneName" />
                            }
                            else
                            {

                                @item.Name
                            }
                        </td>
                        <td>
                            @if (editingDroneId == itemId)
                            {
                                <input class="form-control form-control-sm"
                                       type="number" min="0"
                                       @bind="editingDroneQty" />
                            }
                            else
                            {
                                <span class="badge @(item.Quantity > 0 ? "bg-success" : "bg-secondary")">
                                    @item.Quantity
                                </span>
                            }
                        </td>
                        <AuthorizeView Roles="SuperAdmin,Moderator">
                            <Authorized>
                                <td>
                                    @if (editingDroneId == itemId)
                                    {
                                        <button class="btn btn-xs btn-success me-1"
                                                @onclick="() => SaveDrone(itemId)">
                                            ✓
                                        </button>
                                        <button class="btn btn-xs btn-secondary"
                                                @onclick="() => editingDroneId = 0">
                                            ✕
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-xs btn-warning me-1"
                                                @onclick="() => StartDroneEdit(item)">
                                            ✎
                                        </button>
                                        <button class="btn btn-xs btn-danger"
                                                @onclick="() => DeleteDrone(itemId)">
                                            🗑
                                        </button>
                                    }
                                </td>
                            </Authorized>
                        </AuthorizeView>
                    </tr>
                }
                @if (!items.Any())
                {
                    <tr>
                        <td colspan="3" class="text-muted text-center py-2">Немає позицій</td>
                    </tr>
                }
            </tbody>
        </table>
    };

    /// <summary>Картка FPV безпілотників.</summary>
    private RenderFragment RenderDroneCard(string title, List<DroneItem> items) => __builder =>
    {
        <div class="card">
            <div class="card-header fw-bold">@title</div>
            <div class="card-body p-0">@RenderDroneTable(items)</div>
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <div class="card-footer">
                        @if (showAddDroneForm)
                        {
                            <div class="d-flex gap-2">
                                <input class="form-control form-control-sm"
                                       @bind="newDroneName" placeholder="Назва" />
                                <input class="form-control form-control-sm"
                                       type="number" min="0"
                                       @bind="newDroneQty" style="width:80px;" />
                                <button class="btn btn-sm btn-success" @onclick="AddDrone">+</button>
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => showAddDroneForm = false">
                                    ✕
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary w-100"
                                    @onclick="() => showAddDroneForm = true">
                                + Додати безпілотник
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    };

    /// <summary>Картка бомберів.</summary>
    private RenderFragment RenderBomberCard() => __builder =>
    {
        <div class="card">
            <div class="card-header fw-bold">🚁 Бомбери</div>
            <div class="card-body p-0">@RenderDroneTable(bombers)</div>
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <div class="card-footer">
                        @if (showAddBomberForm)
                        {
                            <div class="d-flex gap-2">
                                <input class="form-control form-control-sm"
                                       @bind="newBomberName"
                                       placeholder="Назва (напр. БПАК Vampire)" />
                                <input class="form-control form-control-sm"
                                       type="number" min="0"
                                       @bind="newBomberQty" style="width:80px;" />
                                <button class="btn btn-sm btn-success" @onclick="AddBomber">+</button>
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => showAddBomberForm = false">
                                    ✕
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary w-100"
                                    @onclick="() => showAddBomberForm = true">
                                + Додати бомбер
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    };

    /// <summary>Картка крил.</summary>
    private RenderFragment RenderWingCard() => __builder =>
    {
        <div class="card">
            <div class="card-header fw-bold">🛩️ Крила</div>
            <div class="card-body p-0">@RenderDroneTable(wings)</div>
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <div class="card-footer">
                        @if (showAddWingForm)
                        {
                            <div class="d-flex gap-2">
                                <input class="form-control form-control-sm"
                                       @bind="newWingName" placeholder="Назва крила" />
                                <input class="form-control form-control-sm"
                                       type="number" min="0"
                                       @bind="newWingQty" style="width:80px;" />
                                <button class="btn btn-sm btn-success" @onclick="AddWing">+</button>
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => showAddWingForm = false">
                                    ✕
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary w-100"
                                    @onclick="() => showAddWingForm = true">
                                + Додати крило
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    };

    /// <summary>Картка боєкомплекту.</summary>
    private RenderFragment RenderAmmoCard() => __builder =>
    {
        <div class="card">
            <div class="card-header fw-bold">💣 Боєкомплект</div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Назва</th>
                            <th style="width:110px;">Кількість</th>
                            <AuthorizeView Roles="SuperAdmin,Moderator">
                                <Authorized><th style="width:80px;">Дії</th></Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ammos)
                        {
                            var itemId = item.Id;
                            <tr>
                                <td>
                                    @if (editingAmmoId == itemId)
                                    {
                                        <input class="form-control form-control-sm"
                                               @bind="editingAmmoName" />
                                    }
                                    else
                                    {

                                        @item.Name
                                    }
                                </td>
                                <td>
                                    @if (editingAmmoId == itemId)
                                    {
                                        <input class="form-control form-control-sm"
                                               type="number" min="0"
                                               @bind="editingAmmoQty" />
                                    }
                                    else
                                    {
                                        <span class="badge @(item.Quantity > 0 ? "bg-success" : "bg-secondary")">
                                            @item.Quantity
                                        </span>
                                    }
                                </td>
                                <AuthorizeView Roles="SuperAdmin,Moderator">
                                    <Authorized>
                                        <td>
                                            @if (editingAmmoId == itemId)
                                            {
                                                <button class="btn btn-xs btn-success me-1"
                                                        @onclick="() => SaveAmmo(itemId)">
                                                    ✓
                                                </button>
                                                <button class="btn btn-xs btn-secondary"
                                                        @onclick="() => editingAmmoId = 0">
                                                    ✕
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-xs btn-warning me-1"
                                                        @onclick="() => StartAmmoEdit(item)">
                                                    ✎
                                                </button>
                                                <button class="btn btn-xs btn-danger"
                                                        @onclick="() => DeleteAmmo(itemId)">
                                                    🗑
                                                </button>
                                            }
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                        @if (!ammos.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-muted text-center py-2">
                                    Немає позицій
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <div class="card-footer">
                        @if (showAddAmmoForm)
                        {
                            <div class="d-flex gap-2">
                                <input class="form-control form-control-sm"
                                       @bind="newAmmoName" placeholder="Назва" />
                                <input class="form-control form-control-sm"
                                       type="number" min="0"
                                       @bind="newAmmoQty" style="width:80px;" />
                                <button class="btn btn-sm btn-success" @onclick="AddAmmo">+</button>
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => showAddAmmoForm = false">
                                    ✕
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary w-100"
                                    @onclick="() => showAddAmmoForm = true">
                                + Додати боєкомплект
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    };

    // ════════════════════════════════════════════════════════════════════════
    // ІНІЦІАЛІЗАЦІЯ
    // ════════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = authState.User.Identity?.Name ?? "";

        companies = await WarehouseService.GetCompaniesAsync();

        if (companies.Any())
        {
            selectedCompanyId = companies.First().Id;
            selectedCompany = companies.First();
            await LoadCompanyData();
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // ВИБІР РОТИ / ЕКІПАЖУ
    // ════════════════════════════════════════════════════════════════════════
    private async Task SelectCompany(int id)
    {
        selectedCompanyId = id;
        selectedCompany = companies?.FirstOrDefault(c => c.Id == id);
        selectedCrewId = 0;
        selectedCrew = null;
        await LoadCompanyData();
    }

    /// <summary>Завантажує екіпажі і дані складу для вибраної роти.</summary>
    private async Task LoadCompanyData()
    {
        crews = await CrewService.GetCrewsAsync(selectedCompanyId);
        warehouseDrones = await CrewService.GetWarehouseDronesAsync(selectedCompanyId);
        warehouseAmmos = await CrewService.GetWarehouseAmmosAsync(selectedCompanyId);

        if (crews.Any())
        {
            selectedCrewId = crews.First().Id;
            selectedCrew = crews.First();
            SetTransferTypeForCrew();
            await LoadCrewData();
        }
        else
        {
            selectedCrew = null;
        }
    }

    private async Task SelectCrew(int id)
    {
        selectedCrewId = id;
        selectedCrew = crews.FirstOrDefault(c => c.Id == id);

        // Скидаємо стан форм
        editingDroneId = 0;
        editingAmmoId = 0;
        showAddDroneForm = false;
        showAddAmmoForm = false;
        showAddBomberForm = false;
        showAddWingForm = false;
        transferMessage = "";
        transferItemId = 0;

        SetTransferTypeForCrew();
        await LoadCrewData();
    }

    /// <summary>Встановлює тип передачі відповідно до типу екіпажу.</summary>
    private void SetTransferTypeForCrew()
    {
        transferType = selectedCrew?.Type switch
        {
            CrewType.Бомбер => "bomber",
            CrewType.Крило => "wing",
            _ => "drone"
        };
    }

    /// <summary>Завантажує запаси та журнал вибраного екіпажу.</summary>
    private async Task LoadCrewData()
    {
        var allDrones = await CrewService.GetDroneItemsAsync(selectedCrewId);

        drones = allDrones.Where(d => !d.IsBomber && !d.IsWing).ToList();
        bombers = allDrones.Where(d => d.IsBomber).ToList();
        wings = allDrones.Where(d => d.IsWing).ToList();

        ammos = await CrewService.GetAmmoItemsAsync(selectedCrewId);
        allCrewLogs = await CrewService.GetLogsAsync(selectedCrewId);

        ApplyCrewLogFilter();
    }

    // ════════════════════════════════════════════════════════════════════════
    // ЕКІПАЖІ — CRUD
    // ════════════════════════════════════════════════════════════════════════
    private async Task AddCrew()
    {
        if (string.IsNullOrWhiteSpace(newCrewName)) return;

        var maxOrder = crews.Any() ? crews.Max(c => c.SortOrder) : 0;
        var crew = await CrewService.AddCrewAsync(
            selectedCompanyId, newCrewName, newCrewType, maxOrder);

        newCrewName = "";
        showAddCrewForm = false;

        await LoadCompanyData();

        selectedCrewId = crew.Id;
        selectedCrew = crews.FirstOrDefault(c => c.Id == crew.Id);
        SetTransferTypeForCrew();
        await LoadCrewData();
    }

    private void ShowDeleteCrewConfirm(int id, string name)
    {
        deletingCrewId = id;
        deletingCrewName = name;
        showDeleteCrewConfirm = true;
    }

    private async Task DeleteCrew()
    {
        try
        {
            await CrewService.DeleteCrewAsync(deletingCrewId);

            showDeleteCrewConfirm = false;
            selectedCrewId = 0;
            selectedCrew = null;
            drones = new(); bombers = new(); wings = new(); ammos = new();
            allCrewLogs = new(); filteredCrewLogs = new(); pagedCrewLogs = new();

            await LoadCompanyData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"DeleteCrew error: {ex.Message}");
            showDeleteCrewConfirm = false;
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // БЕЗПІЛОТНИКИ — CRUD
    // ════════════════════════════════════════════════════════════════════════
    private async Task AddDrone()
    {
        if (string.IsNullOrWhiteSpace(newDroneName)) return;
        await CrewService.AddDroneItemAsync(
            selectedCrewId, newDroneName, newDroneQty, false, false, currentUser);
        newDroneName = ""; newDroneQty = 0; showAddDroneForm = false;
        await LoadCrewData();
    }

    private async Task AddBomber()
    {
        if (string.IsNullOrWhiteSpace(newBomberName)) return;
        await CrewService.AddDroneItemAsync(
            selectedCrewId, newBomberName, newBomberQty, true, false, currentUser);
        newBomberName = ""; newBomberQty = 0; showAddBomberForm = false;
        await LoadCrewData();
    }

    private async Task AddWing()
    {
        if (string.IsNullOrWhiteSpace(newWingName)) return;
        await CrewService.AddDroneItemAsync(
            selectedCrewId, newWingName, newWingQty, false, true, currentUser);
        newWingName = ""; newWingQty = 0; showAddWingForm = false;
        await LoadCrewData();
    }

    private void StartDroneEdit(DroneItem item)
    {
        editingDroneId = item.Id;
        editingDroneName = item.Name;
        editingDroneQty = item.Quantity;
    }

    private async Task SaveDrone(int id)
    {
        await CrewService.SaveDroneItemAsync(id, editingDroneName, editingDroneQty, currentUser);
        editingDroneId = 0;
        await LoadCrewData();
    }

    private async Task DeleteDrone(int id)
    {
        await CrewService.DeleteDroneItemAsync(id, currentUser);
        await LoadCrewData();
    }

    // ════════════════════════════════════════════════════════════════════════
    // БОЄКОМПЛЕКТ — CRUD
    // ════════════════════════════════════════════════════════════════════════
    private async Task AddAmmo()
    {
        if (string.IsNullOrWhiteSpace(newAmmoName)) return;
        await CrewService.AddAmmoItemAsync(
            selectedCrewId, newAmmoName, newAmmoQty, currentUser);
        newAmmoName = ""; newAmmoQty = 0; showAddAmmoForm = false;
        await LoadCrewData();
    }

    private void StartAmmoEdit(AmmoItem item)
    {
        editingAmmoId = item.Id;
        editingAmmoName = item.Name;
        editingAmmoQty = item.Quantity;
    }

    private async Task SaveAmmo(int id)
    {
        await CrewService.SaveAmmoItemAsync(id, editingAmmoName, editingAmmoQty, currentUser);
        editingAmmoId = 0;
        await LoadCrewData();
    }

    private async Task DeleteAmmo(int id)
    {
        await CrewService.DeleteAmmoItemAsync(id, currentUser);
        await LoadCrewData();
    }

    // ════════════════════════════════════════════════════════════════════════
    // ПЕРЕДАЧА ЗІ СКЛАДУ
    // ════════════════════════════════════════════════════════════════════════
    private async Task OnTransferTypeChanged()
    {
        transferItemId = 0;

        if (transferType is "drone" or "bomber" or "wing")
            warehouseDrones = await CrewService.GetWarehouseDronesAsync(selectedCompanyId);
        else
            warehouseAmmos = await CrewService.GetWarehouseAmmosAsync(selectedCompanyId);
    }

    private async Task TransferFromWarehouse()
    {
        transferMessage = "";

        if (transferItemId == 0)
        {
            transferMessage = "Оберіть позицію зі складу.";
            transferSuccess = false;
            return;
        }

        if (transferQty <= 0)
        {
            transferMessage = "Введіть кількість більше 0.";
            transferSuccess = false;
            return;
        }

        if (transferType is "drone" or "bomber" or "wing")
        {
            transferMessage = await CrewService.TransferDroneFromWarehouseAsync(
                selectedCompanyId, selectedCrewId,
                transferItemId, transferQty, transferType, currentUser);
        }
        else
        {
            transferMessage = await CrewService.TransferAmmoFromWarehouseAsync(
                selectedCompanyId, selectedCrewId,
                transferItemId, transferQty, currentUser);
        }

        transferSuccess = !transferMessage.StartsWith("Недостатньо");
        transferItemId = 0;
        transferQty = 1;

        await OnTransferTypeChanged();
        await LoadCrewData();
    }

    // ════════════════════════════════════════════════════════════════════════
    // ЖУРНАЛ
    // ════════════════════════════════════════════════════════════════════════
    private void ApplyCrewLogFilter()
    {
        var q = allCrewLogs.AsEnumerable();

        if (!string.IsNullOrEmpty(crewLogFilterType))
            q = q.Where(l => l.ItemType == crewLogFilterType);

        if (crewLogFilterFrom.HasValue)
            q = q.Where(l => DateOnly.FromDateTime(l.ChangedAt) >= crewLogFilterFrom.Value);

        if (crewLogFilterTo.HasValue)
            q = q.Where(l => DateOnly.FromDateTime(l.ChangedAt) <= crewLogFilterTo.Value);

        q = crewLogSortDesc
            ? q.OrderByDescending(l => l.ChangedAt)
            : q.OrderBy(l => l.ChangedAt);

        filteredCrewLogs = q.ToList();
        crewLogPage = 1;

        UpdatePagedCrewLogs();
    }

    private void ResetCrewLogFilter()
    {
        crewLogFilterFrom = null;
        crewLogFilterTo = null;
        crewLogFilterType = "";
        ApplyCrewLogFilter();
    }

    private void SortCrewLogs()
    {
        crewLogSortDesc = !crewLogSortDesc;
        ApplyCrewLogFilter();
    }

    private void UpdatePagedCrewLogs()
    {
        pagedCrewLogs = filteredCrewLogs
            .Skip((crewLogPage - 1) * crewLogPageSize)
            .Take(crewLogPageSize)
            .ToList();
    }

    private void GoToCrewLogPage(int page)
    {
        if (page >= 1 && page <= crewLogTotalPages)
        {
            crewLogPage = page;
            UpdatePagedCrewLogs();
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // ДОПОМІЖНІ МЕТОДИ
    // ════════════════════════════════════════════════════════════════════════
    private string GetLogBadge(string action) => action switch
    {
        "Додано" => "bg-success",
        "Змінено" => "bg-warning text-dark",
        "Видалено" => "bg-danger",
        "Поповнено зі складу" => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private string GetCrewTypeBadge(CrewType type) => type switch
    {
        CrewType.FPV => "bg-danger",
        CrewType.Бомбер => "bg-primary",
        CrewType.Крило => "bg-success",
        _ => "bg-secondary"
    };
}
