    // ── Передача зі складу ───────────────────────────────────────────────
    private async Task OnTransferTypeChanged()
    {
        transferItemId = 0;
        if (transferType is "drone" or "bomber" or "wing")
        {
            warehouseDrones = await Db.WarehouseDroneItems
                .Where(d => d.CompanyId == selectedCompanyId && d.Quantity > 0)
                .OrderBy(d => d.Name).ToListAsync();
        }
        else
        {
            warehouseAmmos = await Db.WarehouseAmmoItems
                .Where(a => a.CompanyId == selectedCompanyId && a.Quantity > 0)
                .OrderBy(a => a.Name).ToListAsync();
        }
    }

    private async Task TransferFromWarehouse()
    {
        transferMessage = "";
        if (transferItemId == 0) { transferMessage = "Оберіть позицію зі складу."; transferSuccess = false; return; }
        if (transferQty <= 0) { transferMessage = "Введіть кількість більше 0."; transferSuccess = false; return; }

        if (transferType is "drone" or "bomber" or "wing")
        {
            var wItem = await Db.WarehouseDroneItems.FindAsync(transferItemId);
            if (wItem == null || wItem.Quantity < transferQty) { transferMessage = "Недостатньо на складі."; transferSuccess = false; return; }

            bool isBomber = transferType == "bomber";
            bool isWing = transferType == "wing";

            var crewList = transferType == "bomber" ? bombers : transferType == "wing" ? wings : drones;
            var crewItem = crewList.FirstOrDefault(d => d.Name.Equals(wItem.Name, StringComparison.OrdinalIgnoreCase));

            if (crewItem != null)
            {
                await AddCrewLog("Дрон", crewItem.Name, crewItem.Quantity, crewItem.Quantity + transferQty, "Поповнено зі складу");
                crewItem.Quantity += transferQty;
            }
            else
            {
                var newItem = new DroneItem { CrewId = selectedCrewId, Name = wItem.Name, Quantity = transferQty, IsBomber = isBomber, IsWing = isWing };
                Db.DroneItems.Add(newItem);
                await Db.SaveChangesAsync();
                await AddCrewLog("Дрон", wItem.Name, 0, transferQty, "Поповнено зі складу");
            }
            wItem.Quantity -= transferQty;
            await Db.SaveChangesAsync();
            transferMessage = $"Передано {transferQty} шт. '{wItem.Name}' екіпажу.";
        }
        else
        {
            var wItem = await Db.WarehouseAmmoItems.FindAsync(transferItemId);
            if (wItem == null || wItem.Quantity < transferQty) { transferMessage = "Недостатньо на складі."; transferSuccess = false; return; }
            var crewItem = ammos.FirstOrDefault(a => a.Name.Equals(wItem.Name, StringComparison.OrdinalIgnoreCase));
            if (crewItem != null)
            {
                await AddCrewLog("Боєкомплект", crewItem.Name, crewItem.Quantity, crewItem.Quantity + transferQty, "Поповнено зі складу");
                crewItem.Quantity += transferQty;
            }
            else
            {
                var newItem = new AmmoItem { CrewId = selectedCrewId, Name = wItem.Name, Quantity = transferQty };
                Db.AmmoItems.Add(newItem);
                await Db.SaveChangesAsync();
                await AddCrewLog("Боєкомплект", wItem.Name, 0, transferQty, "Поповнено зі складу");
            }
            wItem.Quantity -= transferQty;
            await Db.SaveChangesAsync();
            transferMessage = $"Передано {transferQty} шт. '{wItem.Name}' екіпажу.";
        }

        transferSuccess = true;
        transferItemId = 0; transferQty = 1;
        await OnTransferTypeChanged();
        await LoadCrewData();
    }

    // ── Журнал ───────────────────────────────────────────────────────────
    private async Task AddCrewLog(string itemType, string itemName, int qtyBefore, int qtyAfter, string action)
    {
        Db.CrewLogs.Add(new CrewLog
        {
            CrewId = selectedCrewId,
            ItemType = itemType,
            ItemName = itemName,
            QuantityBefore = qtyBefore,
            QuantityAfter = qtyAfter,
            Action = action,
            ChangedBy = currentUser,
            ChangedAt = DateTime.Now
        });
        await Db.SaveChangesAsync();
    }

    private void ApplyCrewLogFilter()
    {
        var q = allCrewLogs.AsEnumerable();
        if (!string.IsNullOrEmpty(crewLogFilterType)) q = q.Where(l => l.ItemType == crewLogFilterType);
        if (crewLogFilterFrom.HasValue) q = q.Where(l => DateOnly.FromDateTime(l.ChangedAt) >= crewLogFilterFrom.Value);
        if (crewLogFilterTo.HasValue) q = q.Where(l => DateOnly.FromDateTime(l.ChangedAt) <= crewLogFilterTo.Value);
        q = crewLogSortDesc ? q.OrderByDescending(l => l.ChangedAt) : q.OrderBy(l => l.ChangedAt);
        filteredCrewLogs = q.ToList();
        crewLogPage = 1;
        UpdatePagedCrewLogs();
    }

    private void ResetCrewLogFilter() { crewLogFilterFrom = null; crewLogFilterTo = null; crewLogFilterType = ""; ApplyCrewLogFilter(); }
    private void SortCrewLogs() { crewLogSortDesc = !crewLogSortDesc; ApplyCrewLogFilter(); }
    private void UpdatePagedCrewLogs() { pagedCrewLogs = filteredCrewLogs.Skip((crewLogPage - 1) * crewLogPageSize).Take(crewLogPageSize).ToList(); }
    private void GoToCrewLogPage(int page) { if (page >= 1 && page <= crewLogTotalPages) { crewLogPage = page; UpdatePagedCrewLogs(); } }

    private string GetLogBadge(string action) => action switch
    {
        "Додано" => "bg-success",
        "Змінено" => "bg-warning text-dark",
        "Видалено" => "bg-danger",
        "Поповнено зі складу" => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private string GetCrewTypeBadge(CrewType type) => type switch
    {
        CrewType.FPV => "bg-danger",
        CrewType.Бомбер => "bg-primary",
        CrewType.Крило => "bg-success",
        _ => "bg-secondary"
    };
}
