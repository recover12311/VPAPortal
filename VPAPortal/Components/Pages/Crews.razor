    // ════════════════════════════════════════════════════════════════════════
    // CODE
    // ════════════════════════════════════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = authState.User.Identity?.Name ?? "";
        companies = await Db.Companies.OrderBy(c => c.SortOrder).ToListAsync();
        if (companies.Any())
        {
            selectedCompanyId = companies.First().Id;
            selectedCompany = companies.First();
            await LoadCompanyCrews();
        }
    }

    private async Task SelectCompany(int id)
    {
        selectedCompanyId = id;
        selectedCompany = companies?.FirstOrDefault(c => c.Id == id);
        selectedCrewId = 0; selectedCrew = null;
        await LoadCompanyCrews();
    }

    private async Task LoadCompanyCrews()
    {
        crews = await Db.Crews
            .Where(c => c.CompanyId == selectedCompanyId)
            .OrderBy(c => c.SortOrder).ToListAsync();

        warehouseDrones = await Db.WarehouseDroneItems
            .Where(d => d.CompanyId == selectedCompanyId && d.Quantity > 0)
            .OrderBy(d => d.Name).ToListAsync();

        warehouseAmmos = await Db.WarehouseAmmoItems
            .Where(a => a.CompanyId == selectedCompanyId && a.Quantity > 0)
            .OrderBy(a => a.Name).ToListAsync();

        if (crews.Any())
        {
            selectedCrewId = crews.First().Id;
            selectedCrew = crews.First();
            SetTransferTypeForCrew();
            await LoadCrewData();
        }
        else { selectedCrew = null; }
    }

    private async Task SelectCrew(int id)
    {
        selectedCrewId = id;
        selectedCrew = crews.FirstOrDefault(c => c.Id == id);
        editingDroneId = 0; editingAmmoId = 0;
        showAddDroneForm = false; showAddAmmoForm = false;
        showAddBomberForm = false; showAddWingForm = false;
        transferMessage = ""; transferItemId = 0;
        SetTransferTypeForCrew();
        await LoadCrewData();
    }

    private void SetTransferTypeForCrew()
    {
        transferType = selectedCrew?.Type switch
        {
            CrewType.Бомбер => "bomber",
            CrewType.Крило => "wing",
            _ => "drone"
        };
    }

    private async Task LoadCrewData()
    {
        var allDrones = await Db.DroneItems
            .Where(d => d.CrewId == selectedCrewId)
            .OrderBy(d => d.Name).ToListAsync();

        drones = allDrones.Where(d => !d.IsBomber && !d.IsWing).ToList();
        bombers = allDrones.Where(d => d.IsBomber).ToList();
        wings = allDrones.Where(d => d.IsWing).ToList();

        ammos = await Db.AmmoItems
            .Where(a => a.CrewId == selectedCrewId)
            .OrderBy(a => a.Name).ToListAsync();

        allCrewLogs = await Db.CrewLogs
            .Where(l => l.CrewId == selectedCrewId)
            .OrderByDescending(l => l.ChangedAt).ToListAsync();

        ApplyCrewLogFilter();
    }

    // ── Екіпажі ──────────────────────────────────────────────────────────
    private async Task AddCrew()
    {
        if (string.IsNullOrWhiteSpace(newCrewName)) return;
        var maxOrder = crews.Any() ? crews.Max(c => c.SortOrder) : 0;
        var crew = new Crew
        {
            CompanyId = selectedCompanyId,
            Name = newCrewName.Trim(),
            Type = newCrewType,
            SortOrder = maxOrder + 1
        };
        Db.Crews.Add(crew);
        await Db.SaveChangesAsync();
        newCrewName = ""; showAddCrewForm = false;
        await LoadCompanyCrews();
        selectedCrewId = crew.Id;
        selectedCrew = crews.FirstOrDefault(c => c.Id == crew.Id);
        SetTransferTypeForCrew();
        await LoadCrewData();
    }

    private void ShowDeleteCrewConfirm(int id, string name)
    {
        deletingCrewId = id; deletingCrewName = name; showDeleteCrewConfirm = true;
    }

    private async Task DeleteCrew()
    {
        try
        {
            var crew = await Db.Crews.FindAsync(deletingCrewId);
            if (crew != null)
            {
                Db.DroneItems.RemoveRange(Db.DroneItems.Where(d => d.CrewId == deletingCrewId));
                Db.AmmoItems.RemoveRange(Db.AmmoItems.Where(a => a.CrewId == deletingCrewId));
                Db.CrewLogs.RemoveRange(Db.CrewLogs.Where(l => l.CrewId == deletingCrewId));
                var flights = await Db.Flights.Include(f => f.Drops)
                    .Where(f => f.CrewId == deletingCrewId).ToListAsync();
                foreach (var flight in flights) Db.FlightDrops.RemoveRange(flight.Drops);
                Db.Flights.RemoveRange(flights);
                Db.Crews.Remove(crew);
                await Db.SaveChangesAsync();
            }
            showDeleteCrewConfirm = false;
            selectedCrewId = 0; selectedCrew = null;
            drones = new(); bombers = new(); wings = new(); ammos = new();
            allCrewLogs = new(); filteredCrewLogs = new(); pagedCrewLogs = new();
            crews = await Db.Crews.Where(c => c.CompanyId == selectedCompanyId)
                .OrderBy(c => c.SortOrder).ToListAsync();
            warehouseDrones = await Db.WarehouseDroneItems
                .Where(d => d.CompanyId == selectedCompanyId && d.Quantity > 0)
                .OrderBy(d => d.Name).ToListAsync();
            warehouseAmmos = await Db.WarehouseAmmoItems
                .Where(a => a.CompanyId == selectedCompanyId && a.Quantity > 0)
                .OrderBy(a => a.Name).ToListAsync();
            if (crews.Any())
            {
                selectedCrewId = crews.First().Id;
                selectedCrew = crews.First();
                SetTransferTypeForCrew();
                await LoadCrewData();
            }
        }
        catch (Exception ex) { Console.WriteLine($"DeleteCrew error: {ex.Message}"); showDeleteCrewConfirm = false; }
    }

    // ── FPV дрони ────────────────────────────────────────────────────────
    private async Task AddDrone()
    {
        if (string.IsNullOrWhiteSpace(newDroneName)) return;
        var existing = drones.FirstOrDefault(d =>
            d.Name.Equals(newDroneName.Trim(), StringComparison.OrdinalIgnoreCase));
        if (existing != null)
        {
            await AddCrewLog("Дрон", existing.Name, existing.Quantity, existing.Quantity + newDroneQty, "Додано");
            existing.Quantity += newDroneQty;
            await Db.SaveChangesAsync();
        }
        else
        {
            var item = new DroneItem { CrewId = selectedCrewId, Name = newDroneName.Trim(), Quantity = newDroneQty, IsBomber = false, IsWing = false };
            Db.DroneItems.Add(item);
            await Db.SaveChangesAsync();
            await AddCrewLog("Дрон", item.Name, 0, newDroneQty, "Додано");
        }
        newDroneName = ""; newDroneQty = 0; showAddDroneForm = false;
        await LoadCrewData();
    }

