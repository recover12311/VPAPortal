@page "/crews"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using VPAPortal.Common
@using VPAPortal.Data
@using VPAPortal.Data.Models
@attribute [Authorize]
@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Екіпажі</PageTitle>

<div class="page-title-bar crews">
    <span class="page-icon">👥</span>
    <h3>Екіпажі</h3>
</div>

@if (companies == null)
{
    <p>Завантаження...</p>
}
else
{
    @* ===== ВКЛАДКИ РОТ ===== *@
    <ul class="nav nav-tabs mb-2">
        @foreach (var company in companies)
        {
            var cId = company.Id;
            <li class="nav-item">
                <button class="nav-link @(selectedCompanyId == cId ? "active" : "")"
                        @onclick="() => SelectCompany(cId)">
                    @company.Name
                </button>
            </li>
        }
    </ul>

    @if (selectedCompany != null)
    {
        @* ===== ВКЛАДКИ ЕКІПАЖІВ ===== *@
        <div class="d-flex align-items-center flex-wrap gap-2 mb-4"
             style="border-bottom: 1px solid #dee2e6; padding-bottom: 0;">
            <ul class="nav nav-tabs flex-nowrap mb-0" style="border-bottom:none;">
                @foreach (var crew in crews)
                {
                    var crewId = crew.Id;
                    <li class="nav-item">
                        <button class="nav-link @(selectedCrewId == crewId ? "active" : "")"
                                @onclick="() => SelectCrew(crewId)">
                            @crew.Name
                            <span class="badge @GetCrewTypeBadge(crew.Type) ms-1"
                                  style="font-size:0.65rem;">
                                @crew.Type
                            </span>
                        </button>
                    </li>
                }
            </ul>
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    @if (!showAddCrewForm)
                    {
                        <button class="btn btn-sm btn-outline-success ms-2"
                                @onclick="() => showAddCrewForm = true">
                            + Екіпаж
                        </button>
                    }
                    else
                    {
                        <div class="d-flex gap-2 align-items-center ms-2">
                            <input class="form-control form-control-sm" style="width:130px;"
                                   @bind="newCrewName" placeholder="Назва" />
                            <select class="form-select form-select-sm" style="width:120px;"
                                    @bind="newCrewType">
                                <option value="@CrewType.FPV">FPV</option>
                                <option value="@CrewType.Бомбер">Бомбер</option>
                                <option value="@CrewType.Крило">Крило</option>
                            </select>
                            <button class="btn btn-sm btn-success" @onclick="AddCrew">
                                Додати
                            </button>
                            <button class="btn btn-sm btn-secondary"
                                    @onclick="() => showAddCrewForm = false">
                                ✕
                            </button>
                        </div>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (selectedCrew != null)
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="mb-0 d-inline">@selectedCrew.Name</h5>
                    <span class="badge @GetCrewTypeBadge(selectedCrew.Type) ms-2">
                        @selectedCrew.Type
                    </span>
                </div>
                <AuthorizeView Roles="SuperAdmin,Moderator">
                    <Authorized>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => ShowDeleteCrewConfirm(selectedCrew.Id, selectedCrew.Name)">
                            🗑 Видалити екіпаж
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>

            @if (showDeleteCrewConfirm)
            {
                <div class="alert alert-danger d-flex align-items-center gap-3 mb-3">
                    <span>Видалити <strong>@deletingCrewName</strong> та всі його дані?</span>
                    <button class="btn btn-sm btn-danger" @onclick="DeleteCrew">Так, видалити</button>
                    <button class="btn btn-sm btn-secondary"
                            @onclick="() => showDeleteCrewConfirm = false">
                        Скасувати
                    </button>
                </div>
            }

            @* ===== ЗАПАСИ ЕКІПАЖУ ===== *@
            <div class="row g-4 align-items-start mb-4">

                @* БЕЗПІЛОТНИКИ — FPV *@
                @if (selectedCrew.Type == CrewType.FPV)
                {
                    <div class="col-md-6">
                        @RenderDroneCard("🚁 Безпілотники", drones, false)
                    </div>
                }

                @* БЕЗПІЛОТНИКИ — БОМБЕР *@
                @if (selectedCrew.Type == CrewType.Бомбер)
                {
                    <div class="col-md-6">
                        @RenderBomberCard()
                    </div>
                }

                @* БЕЗПІЛОТНИКИ — КРИЛО *@
                @if (selectedCrew.Type == CrewType.Крило)
                {
                    <div class="col-md-6">
                        @RenderWingCard()
                    </div>
                }

                @* БОЄКОМПЛЕКТ — тільки для FPV та Бомбер *@
                @if (selectedCrew.Type == CrewType.FPV || selectedCrew.Type == CrewType.Бомбер)
                {
                    <div class="col-md-6">
                        @RenderAmmoCard()
                    </div>
                }
            </div>

            @* ===== ПОПОВНЕННЯ ЗІ СКЛАДУ ===== *@
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <div class="card mb-4">
                        <div class="card-header fw-bold">
                            📦 Поповнити зі складу роти (@selectedCompany?.Name)
                        </div>
                        <div class="card-body">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-2">
                                    <label class="form-label">Тип</label>
                                    <select class="form-select" @bind="transferType"
                                            @bind:after="OnTransferTypeChanged">
                                        @if (selectedCrew.Type == CrewType.FPV)
                                        {
                                            <option value="drone">Безпілотник</option>
                                            <option value="ammo">Боєкомплект</option>
                                        }
                                        else if (selectedCrew.Type == CrewType.Бомбер)
                                        {
                                            <option value="bomber">Бомбер</option>
                                            <option value="ammo">Боєкомплект</option>
                                        }
                                        else if (selectedCrew.Type == CrewType.Крило)
                                        {
                                            <option value="wing">Крило</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Назва зі складу</label>
                                    <select class="form-select" @bind="transferItemId">
                                        <option value="0">— оберіть —</option>
                                        @if (transferType == "drone" || transferType == "bomber" || transferType == "wing")
                                        {
                                            @foreach (var d in warehouseDrones)
                                            {
                                                <option value="@d.Id">@d.Name (на складі: @d.Quantity)</option>
                                            }
                                        }
                                        else
                                        {
                                            @foreach (var a in warehouseAmmos)
                                            {
                                                <option value="@a.Id">@a.Name (на складі: @a.Quantity)</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Кількість</label>
                                    <input type="number" class="form-control" min="1" @bind="transferQty" />
                                </div>
                                <div class="col-md-2">
                                    <button class="btn btn-success w-100" @onclick="TransferFromWarehouse">
                                        Передати екіпажу
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(transferMessage))
                            {
                                <div class="alert @(transferSuccess ? "alert-success" : "alert-danger") mt-3">
                                    @transferMessage
                                </div>
                            }
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>

            @* ===== ЖУРНАЛ ЕКІПАЖУ ===== *@
            <div class="card">
                <div class="card-header fw-bold">📋 Журнал змін екіпажу</div>
                <div class="card-body">
                    <div class="d-flex gap-2 mb-3 align-items-end flex-wrap">
                        <div>
                            <label class="form-label mb-1 small">Від</label>
                            <input type="date" class="form-control form-control-sm"
                                   @bind="crewLogFilterFrom" @bind:after="ApplyCrewLogFilter" />
                        </div>
                        <div>
                            <label class="form-label mb-1 small">До</label>
                            <input type="date" class="form-control form-control-sm"
                                   @bind="crewLogFilterTo" @bind:after="ApplyCrewLogFilter" />
                        </div>
                        <div>
                            <label class="form-label mb-1 small">Тип</label>
                            <select class="form-select form-select-sm" style="width:160px;"
                                    @bind="crewLogFilterType" @bind:after="ApplyCrewLogFilter">
                                <option value="">— всі —</option>
                                <option value="Дрон">Безпілотник</option>
                                <option value="Боєкомплект">Боєкомплект</option>
                            </select>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ResetCrewLogFilter">
                            ✕ Скинути
                        </button>
                    </div>

                    @if (!filteredCrewLogs.Any())
                    {
                        <p class="text-muted">Записів немає.</p>
                    }
                    else
                    {
                        <table class="table table-sm table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th style="cursor:pointer" @onclick="SortCrewLogs">
                                        Дата @(crewLogSortDesc ? "↓" : "↑")
                                    </th>
                                    <th>Тип</th>
                                    <th>Назва</th>
                                    <th>Дія</th>
                                    <th>Було</th>
                                    <th>Стало</th>
                                    <th>Хто</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in pagedCrewLogs)
                                {
                                    <tr>
                                        <td>@log.ChangedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@log.ItemType</td>
                                        <td>@log.ItemName</td>
                                        <td>
                                            <span class="badge @GetLogBadge(log.Action)">@log.Action</span>
                                        </td>
                                        <td>@log.QuantityBefore</td>
                                        <td>@log.QuantityAfter</td>
                                        <td class="text-muted small">@log.ChangedBy</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        @if (crewLogTotalPages > 1)
                        {
                            <nav>
                                <ul class="pagination mt-2">
                                    <li class="page-item @(crewLogPage == 1 ? "disabled" : "")">
                                        <button class="page-link"
                                                @onclick="() => GoToCrewLogPage(crewLogPage - 1)">
                                            ‹
                                        </button>
                                    </li>
                                    @for (int p = 1; p <= crewLogTotalPages; p++)
                                    {
                                        var pn = p;
                                        <li class="page-item @(crewLogPage == pn ? "active" : "")">
                                            <button class="page-link"
                                                    @onclick="() => GoToCrewLogPage(pn)">
                                                @pn
                                            </button>
                                        </li>
                                    }
                                    <li class="page-item @(crewLogPage == crewLogTotalPages ? "disabled" : "")">
                                        <button class="page-link"
                                                @onclick="() => GoToCrewLogPage(crewLogPage + 1)">
                                            ›
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                            <p class="text-muted small">
                                Всього: @filteredCrewLogs.Count. Сторінка @crewLogPage з @crewLogTotalPages.
                            </p>
                        }
                    }
                </div>
            </div>
        }
    }
}

<style>
    .btn-xs {
        padding: 0.1rem 0.4rem;
        font-size: 0.75rem;
    }
</style>

@code {
    private List<Company>? companies;
    private int selectedCompanyId;
    private Company? selectedCompany;
    private string currentUser = "";

    private List<Crew> crews = new();
    private int selectedCrewId;
    private Crew? selectedCrew;
    private bool showAddCrewForm = false;
    private string newCrewName = "";
    private CrewType newCrewType = CrewType.FPV;
    private bool showDeleteCrewConfirm = false;
    private int deletingCrewId;
    private string deletingCrewName = "";

    // FPV дрони
    private List<DroneItem> drones = new();
    // Бомбери
    private List<DroneItem> bombers = new();
    // Крила (IsBomber = true, але окремо для зручності UI)
    private List<DroneItem> wings = new();

    private bool showAddDroneForm = false;
    private string newDroneName = "";
    private int newDroneQty = 0;

    private bool showAddBomberForm = false;
    private string newBomberName = "";
    private int newBomberQty = 0;

    private bool showAddWingForm = false;
    private string newWingName = "";
    private int newWingQty = 0;

    private int editingDroneId = 0;
    private string editingDroneName = "";
    private int editingDroneQty = 0;

    private List<AmmoItem> ammos = new();
    private bool showAddAmmoForm = false;
    private string newAmmoName = "";
    private int newAmmoQty = 0;
    private int editingAmmoId = 0;
    private string editingAmmoName = "";
    private int editingAmmoQty = 0;

    private string transferType = "drone";
    private int transferItemId = 0;
    private int transferQty = 1;
    private string transferMessage = "";
    private bool transferSuccess = false;
    private List<WarehouseDroneItem> warehouseDrones = new();
    private List<WarehouseAmmoItem> warehouseAmmos = new();

    private List<CrewLog> allCrewLogs = new();
    private List<CrewLog> filteredCrewLogs = new();
    private List<CrewLog> pagedCrewLogs = new();
    private int crewLogPage = 1;
    private int crewLogPageSize = 15;
    private int crewLogTotalPages =>
        (int)Math.Ceiling(filteredCrewLogs.Count / (double)crewLogPageSize);
    private DateOnly? crewLogFilterFrom = null;
    private DateOnly? crewLogFilterTo = null;
    private string crewLogFilterType = "";
    private bool crewLogSortDesc = true;

    // ── RenderFragments для карток ────────────────────────────────────────

    private RenderFragment RenderDroneCard(string title, List<DroneItem> items, bool isBomberType) => __builder =>
    {
        <div class="card">
            <div class="card-header fw-bold">@title</div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Назва</th>
                            <th style="width:110px;">Кількість</th>
                            <AuthorizeView Roles="SuperAdmin,Moderator">
                                <Authorized><th style="width:80px;">Дії</th></Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            var itemId = item.Id;
                            <tr>
                                <td>
                                    @if (editingDroneId == itemId)
                                    {
                                        <input class="form-control form-control-sm" @bind="editingDroneName" />
                                    }
                                    else
                                    {

                                        @item.Name
                                    }
                                </td>
                                <td>
                                    @if (editingDroneId == itemId)
                                    {
                                        <input class="form-control form-control-sm" type="number"
                                               min="0" @bind="editingDroneQty" />
                                    }
                                    else
                                    {
                                        <span class="badge @(item.Quantity > 0 ? "bg-success" : "bg-secondary")">
                                            @item.Quantity
                                        </span>
                                    }
                                </td>
                                <AuthorizeView Roles="SuperAdmin,Moderator">
                                    <Authorized>
                                        <td>
                                            @if (editingDroneId == itemId)
                                            {
                                                <button class="btn btn-xs btn-success me-1"
                                                        @onclick="() => SaveDrone(itemId)">
                                                    ✓
                                                </button>
                                                <button class="btn btn-xs btn-secondary"
                                                        @onclick="() => editingDroneId = 0">
                                                    ✕
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-xs btn-warning me-1"
                                                        @onclick="() => StartDroneEdit(item)">
                                                    ✎
                                                </button>
                                                <button class="btn btn-xs btn-danger"
                                                        @onclick="() => DeleteDrone(itemId)">
                                                    🗑
                                                </button>
                                            }
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                        @if (!items.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-muted text-center py-2">Немає позицій</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <div class="card-footer">
                        @if (showAddDroneForm)
                        {
                            <div class="d-flex gap-2">
                                <input class="form-control form-control-sm" @bind="newDroneName"
                                       placeholder="Назва" />
                                <input class="form-control form-control-sm" type="number"
                                       min="0" @bind="newDroneQty" style="width:80px;" />
                                <button class="btn btn-sm btn-success" @onclick="AddDrone">+</button>
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => showAddDroneForm = false">
                                    ✕
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary w-100"
                                    @onclick="() => showAddDroneForm = true">
                                + Додати безпілотник
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    };

    private RenderFragment RenderBomberCard() => __builder =>
    {
        <div class="card">
            <div class="card-header fw-bold">🚁 Бомбери</div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Назва</th>
                            <th style="width:110px;">Кількість</th>
                            <AuthorizeView Roles="SuperAdmin,Moderator">
                                <Authorized><th style="width:80px;">Дії</th></Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in bombers)
                        {
                            var itemId = item.Id;
                            <tr>
                                <td>
                                    @if (editingDroneId == itemId)
                                    {
                                        <input class="form-control form-control-sm" @bind="editingDroneName" />
                                    }
                                    else
                                    {

                                        @item.Name
                                    }
                                </td>
                                <td>
                                    @if (editingDroneId == itemId)
                                    {
                                        <input class="form-control form-control-sm" type="number"
                                               min="0" @bind="editingDroneQty" />
                                    }
                                    else
                                    {
                                        <span class="badge @(item.Quantity > 0 ? "bg-success" : "bg-secondary")">
                                            @item.Quantity
                                        </span>
                                    }
                                </td>
                                <AuthorizeView Roles="SuperAdmin,Moderator">
                                    <Authorized>
                                        <td>
                                            @if (editingDroneId == itemId)
                                            {
                                                <button class="btn btn-xs btn-success me-1"
                                                        @onclick="() => SaveDrone(itemId)">
                                                    ✓
                                                </button>
                                                <button class="btn btn-xs btn-secondary"
                                                        @onclick="() => editingDroneId = 0">
                                                    ✕
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-xs btn-warning me-1"
                                                        @onclick="() => StartDroneEdit(item)">
                                                    ✎
                                                </button>
                                                <button class="btn btn-xs btn-danger"
                                                        @onclick="() => DeleteDrone(itemId)">
                                                    🗑
                                                </button>
                                            }
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                        @if (!bombers.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-muted text-center py-2">Немає бомберів</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <AuthorizeView Roles="SuperAdmin,Moderator">
                <Authorized>
                    <div class="card-footer">
                        @if (showAddBomberForm)
                        {
                            <div class="d-flex gap-2">
                                <input class="form-control form-control-sm" @bind="newBomberName"
                                       placeholder="Назва (напр. БПАК Vampire)" />
                                <input class="form-control form-control-sm" type="number"
                                       min="0" @bind="newBomberQty" style="width:80px;" />
                                <button class="btn btn-sm btn-success" @onclick="AddBomber">+</button>
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => showAddBomberForm = false">
                                    ✕
                                </button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary w-100"
                                    @onclick="() => showAddBomberForm = true">
                                + Додати бомбер
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    };

    private RenderFragment RenderWingCard() => __builder =>
    {
        <div class="card">
            <div class="card-header fw-bold">🛩️ Крила</div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Назва</th>
                            <th style="width:110px;">Кількість</th>
                            <AuthorizeView Roles="SuperAdmin,Moderator">
                                <Authorized><th style="width:80px;">Дії</th></Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in wings)
                        {
                            var itemId = item.Id;
                            <tr>
                                <td>
                                    @if (editingDroneId == itemId)
                                    {
                                        <input class="form-control form-control-sm" @bind="editingDroneName" />
                                    }
                                    else
                                    {

                                        @item.Name
                                    }
                                </td>
                                <td>
                                    @if (editingDroneId == itemId)
                                    {
                                        <input class="form-control form-control-sm" type="number"
                                               min="0" @bind="editingDroneQty" />
                                    }
                                    else
                                    {
                                        <span class="badge @(item.Quantity > 0 ? "bg-success" : "bg-secondary")">
                                            @item.Quantity
                                        </span>
                                    }
                                </td>
                                <AuthorizeView Roles="SuperAdmin,Moderator">
                                    <Authorized>
                                        <td>
                                            @if (editingDroneId == itemId)
                                            {
                                                <button class="btn btn-xs btn-success me-1"
                                                        @onclick="() => SaveDrone(itemId)">
                                                    ✓
                                                </button>
                                                <button class="btn btn-xs btn-secondary"
                                                        @onclick="() => editingDroneId = 0">
                                                    ✕
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-xs btn-warning me-1"
                                                        @onclick="() => StartDroneEdit(item)">
                                                    ✎
                                                </button>
                                                <button class="btn btn-xs btn-danger"
                                                        @onclick="() => DeleteDrone(itemId)">
                                                    🗑
                                                </button>
                                            }
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                        @if (!wings.Any())
                        {
