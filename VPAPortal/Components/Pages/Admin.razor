@page "/admin"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using VPAPortal.Business.Services.Interfaces
@using VPAPortal.Data
@attribute [Authorize]
@inject IAdminService AdminService

<PageTitle>Адмін</PageTitle>

<div class="page-title-bar admin">
    <span class="page-icon">🛡️</span>
    <h3>Адміністрування</h3>
</div>

@* ===== ВКЛАДКИ ===== *@
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <button class="nav-link @(activeTab == "users" ? "active" : "")"
                @onclick='() => activeTab = "users"'>
            👥 Користувачі
        </button>
    </li>
</ul>

@* ===== ВКЛАДКА КОРИСТУВАЧІВ ===== *@
@if (activeTab == "users")
{
    <AuthorizeView Roles="SuperAdmin">
        <Authorized>

            @* ── Форма створення користувача ── *@
            <div class="card mb-4" style="max-width:480px;">
                <div class="card-header">Додати нового користувача</div>
                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label">Логін</label>
                        <input class="form-control"
                               @bind="newUsername"
                               placeholder="Введіть логін" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Пароль</label>
                        <input class="form-control"
                               type="password"
                               @bind="newPassword"
                               placeholder="Мінімум 6 символів" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Роль</label>
                        <select class="form-select" @bind="newRole">
                            @foreach (var role in availableRoles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                    </div>

                    <button class="btn btn-primary w-100" @onclick="CreateUser">
                        Створити користувача
                    </button>

                    @if (!string.IsNullOrEmpty(createMessage))
                    {
                        <div class="alert @(createSuccess ? "alert-success" : "alert-danger") mt-3">
                            @createMessage
                        </div>
                    }

                </div>
            </div>

            @* ── Модалка зміни пароля ── *@
            @if (showPasswordModal)
            {
                <div class="modal d-block" style="background:rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">

                            <div class="modal-header">
                                <h5 class="modal-title">Змінити пароль — @editingUsername</h5>
                                <button class="btn-close" @onclick="ClosePasswordModal"></button>
                            </div>

                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Новий пароль</label>
                                    <input class="form-control"
                                           type="password"
                                           @bind="newPasswordForEdit"
                                           placeholder="Мінімум 6 символів" />
                                </div>

                                @if (!string.IsNullOrEmpty(passwordChangeMessage))
                                {
                                    <div class="alert @(passwordChangeSuccess ? "alert-success" : "alert-danger")">
                                        @passwordChangeMessage
                                    </div>
                                }
                            </div>

                            <div class="modal-footer">
                                <button class="btn btn-secondary" @onclick="ClosePasswordModal">
                                    Скасувати
                                </button>
                                <button class="btn btn-primary" @onclick="ChangePassword">
                                    Зберегти
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            }

            @* ── Список користувачів ── *@
            <h5>Список користувачів</h5>

            @if (users == null)
            {
                <p>Завантаження...</p>
            }
            else if (!users.Any())
            {
                <p class="text-muted">Користувачів не знайдено.</p>
            }
            else
            {
                <table class="table table-bordered table-hover" style="max-width:900px;">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Логін</th>
                            <th>Роль</th>
                            <th style="width:200px;">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in PagedUsers.Select((u, i) => new { User = u, Index = i }))
                        {
                            var rowNum   = (currentPage - 1) * pageSize + item.Index + 1;
                            var userId   = item.User.Id;
                            var userName = item.User.UserName ?? "";

                            <tr>
                                <td>@rowNum</td>
                                <td>@item.User.UserName</td>
                                <td>
                                    @(userRoles.ContainsKey(item.User.Id)
                                        ? string.Join(", ", userRoles[item.User.Id])
                                        : "—")
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-warning me-1"
                                            @onclick="() => OpenPasswordModal(userId, userName)">
                                        🔑 Пароль
                                    </button>
                                    <button class="btn btn-sm btn-danger"
                                            @onclick="() => DeleteUser(userId)"
                                            disabled="@(item.User.UserName == currentUsername)">
                                        Видалити
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @* ── Пагінація ── *@
                @if (totalPages > 1)
                {
                    <nav>
                        <ul class="pagination">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="PrevPage">&#8249;</button>
                            </li>

                            @for (int p = 1; p <= totalPages; p++)
                            {
                                var pageNum  = p;
                                var isActive = currentPage == pageNum;

                                <li class="page-item @(isActive ? "active" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(pageNum)">
                                        @pageNum
                                    </button>
                                </li>
                            }

                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="NextPage">&#8250;</button>
                            </li>
                        </ul>
                    </nav>

                    <p class="text-muted small">
                        Показано @PagedUsers.Count() з @users.Count.
                        Сторінка @currentPage з @totalPages.
                    </p>
                }
            }

        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning">Доступ тільки для SuperAdmin.</div>
        </NotAuthorized>
    </AuthorizeView>
}

@code {
    // ── Активна вкладка ─────────────────────────────────────────────────────
    private string activeTab = "users";

    // ── Форма створення ─────────────────────────────────────────────────────
    private string newUsername    = "";
    private string newPassword    = "";
    private string newRole        = "Viewer";
    private string createMessage  = "";
    private bool   createSuccess  = false;

    // ── Дані ────────────────────────────────────────────────────────────────
    private List<ApplicationUser>?              users         = null;
    private Dictionary<string, List<string>>    userRoles     = new();
    private List<string>                        availableRoles = new();
    private string                              currentUsername = "";

    // ── Пагінація ───────────────────────────────────────────────────────────
    private int currentPage = 1;
    private int pageSize    = 10;

    private int totalPages => users == null
        ? 1
        : (int)Math.Ceiling(users.Count / (double)pageSize);

    private IEnumerable<ApplicationUser> PagedUsers =>
        users?.Skip((currentPage - 1) * pageSize).Take(pageSize)
        ?? Enumerable.Empty<ApplicationUser>();

    // ── Модалка зміни пароля ────────────────────────────────────────────────
    private bool   showPasswordModal      = false;
    private string editingUserId          = "";
    private string editingUsername        = "";
    private string newPasswordForEdit     = "";
    private string passwordChangeMessage  = "";
    private bool   passwordChangeSuccess  = false;

    // ── Поточний користувач ─────────────────────────────────────────────────
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    // ════════════════════════════════════════════════════════════════════════
    // ІНІЦІАЛІЗАЦІЯ
    // ════════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationState != null)
        {
            var state = await AuthenticationState;
            currentUsername = state.User.Identity?.Name ?? "";
        }

        await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════
    // ЗАВАНТАЖЕННЯ ДАНИХ
    // ════════════════════════════════════════════════════════════════════════
    private async Task LoadData()
    {
        availableRoles = await AdminService.GetAvailableRolesAsync();
        users          = await AdminService.GetUsersAsync();
        userRoles      = await AdminService.GetUserRolesAsync(users);
    }

    // ════════════════════════════════════════════════════════════════════════
    // CRUD КОРИСТУВАЧІВ
    // ════════════════════════════════════════════════════════════════════════

    /// <summary>Створює нового користувача з вибраною роллю.</summary>
    private async Task CreateUser()
    {
        createMessage = "";

        if (string.IsNullOrWhiteSpace(newUsername) || string.IsNullOrWhiteSpace(newPassword))
        {
            createMessage = "Заповніть всі поля.";
            createSuccess = false;
            return;
        }

        var result = await AdminService.CreateUserAsync(newUsername, newPassword, newRole);

        if (result.Succeeded)
        {
            createMessage = $"Користувача '{newUsername}' створено з роллю '{newRole}'.";
            createSuccess = true;

            // Скидаємо форму
            newUsername = "";
            newPassword = "";
            newRole     = "Viewer";

            await LoadData();
        }
        else
        {
            createMessage = "Помилка: " + string.Join(", ", result.Errors.Select(e => e.Description));
            createSuccess = false;
        }
    }

    /// <summary>Видаляє користувача і оновлює список.</summary>
    private async Task DeleteUser(string userId)
    {
        await AdminService.DeleteUserAsync(userId);
        await LoadData();

        // Якщо після видалення поточна сторінка стала порожньою — повертаємось на попередню
        if (currentPage > totalPages && currentPage > 1)
        {
            currentPage--;
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // МОДАЛКА ЗМІНИ ПАРОЛЯ
    // ════════════════════════════════════════════════════════════════════════

    private void OpenPasswordModal(string userId, string username)
    {
        editingUserId         = userId;
        editingUsername       = username;
        newPasswordForEdit    = "";
        passwordChangeMessage = "";
        passwordChangeSuccess = false;
        showPasswordModal     = true;
    }

    private void ClosePasswordModal()
    {
        showPasswordModal     = false;
        editingUserId         = "";
        editingUsername       = "";
        newPasswordForEdit    = "";
        passwordChangeMessage = "";
    }

    /// <summary>Змінює пароль для обраного користувача.</summary>
    private async Task ChangePassword()
    {
        passwordChangeMessage = "";

        if (string.IsNullOrWhiteSpace(newPasswordForEdit))
        {
            passwordChangeMessage = "Введіть новий пароль.";
            passwordChangeSuccess = false;
            return;
        }

        var result = await AdminService.ChangePasswordAsync(editingUserId, newPasswordForEdit);

        if (result.Succeeded)
        {
            passwordChangeMessage = "Пароль успішно змінено.";
            passwordChangeSuccess = true;
        }
        else
        {
            passwordChangeMessage = "Помилка: " + string.Join(", ", result.Errors.Select(e => e.Description));
            passwordChangeSuccess = false;
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // ПАГІНАЦІЯ
    // ════════════════════════════════════════════════════════════════════════
    private void GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
        }
    }

    private void PrevPage() => GoToPage(currentPage - 1);
    private void NextPage() => GoToPage(currentPage + 1);
}
