@page "/flights"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using VPAPortal.Business.DTO
@using VPAPortal.Business.Services.Interfaces
@using VPAPortal.Common
@using VPAPortal.Data.Models
@using VPAPortal.Data.Services
@attribute [Authorize]
@inject IFlightService FlightService
@inject IWarehouseService WarehouseService
@inject AuthenticationStateProvider AuthStateProvider
@inject ICrewService CrewService

<PageTitle>Вильоти</PageTitle>

<div class="page-title-bar flights">
    <span class="page-icon">✈️</span>
    <h3>Вильоти</h3>
</div>

@if (companies == null)
{
    <p>Завантаження...</p>
}
else
{
    @* ===== ВКЛАДКИ РОТ ===== *@
    <ul class="nav nav-tabs mb-2">
        @foreach (var company in companies)
        {
            var cId = company.Id;
            <li class="nav-item">
                <button class="nav-link @(selectedCompanyId == cId ? "active" : "")"
                        @onclick="() => SelectCompany(cId)">
                    @company.Name
                </button>
            </li>
        }
    </ul>

    @* ===== ВКЛАДКИ ЕКІПАЖІВ ===== *@
    @if (crews != null && crews.Any())
    {
        <ul class="nav nav-tabs mb-4">
            @foreach (var crew in crews)
            {
                var crewId = crew.Id;
                <li class="nav-item">
                    <button class="nav-link @(selectedCrewId == crewId ? "active" : "")"
                            @onclick="() => SelectCrew(crewId)">
                        @crew.Name
                        <span class="badge @GetCrewTypeBadge(crew.Type) ms-1"
                              style="font-size:0.65rem;">
                            @crew.Type
                        </span>
                    </button>
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted mb-4">Екіпажів для цієї роти немає.</p>
    }

    @if (selectedCrew != null)
    {
        @* ===== ВИБІР ДАТИ ===== *@
        <div class="d-flex align-items-center gap-3 mb-4 p-3 bg-light rounded">
            <label class="fw-bold mb-0">📅 Дата:</label>
            <input type="date" class="form-control"
                   style="width:180px;"
                   @bind="selectedDate"
                   @bind:after="LoadFlights" />
            <span class="text-muted small">
                Вильоти за @selectedDate.ToString("dd.MM.yyyy")
            </span>
            <span class="badge @GetCrewTypeBadge(selectedCrew.Type)">
                @selectedCrew.Type
            </span>
        </div>

        @* ===== ФОРМА ДОДАВАННЯ ===== *@
        <AuthorizeView Roles="SuperAdmin,Moderator">
            <Authorized>
                <div class="card mb-4">
                    <div class="card-header fw-bold">➕ Додати виліт</div>
                    <div class="card-body">

                        @* ── FPV ── *@
                        @if (selectedCrew.Type == CrewType.FPV)
                        {
                            <div class="row g-3 mb-3">
                                <div class="col-md-2">
                                    <label class="form-label">Час вильоту</label>
                                    <input type="time" class="form-control" @bind="newTime" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Координати</label>
                                    <input class="form-control"
                                           @bind="newCoordinates"
                                           placeholder="36UXB 11111 11111" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Безпілотник</label>
                                    <select class="form-select" @bind="newDroneItemId">
                                        <option value="0">— оберіть —</option>
                                        @foreach (var d in availableDrones)
                                        {
                                            <option value="@d.Id">@d.Name (@d.Quantity)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Населений пункт</label>
                                    <input class="form-control"
                                           @bind="newSettlement"
                                           placeholder="Назва н.п." />
                                </div>
                            </div>

                            <div class="border rounded p-3 mb-3 bg-light">
                                <div class="fw-bold mb-2 text-danger">🎯 Ціль та боєкомплект</div>
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-3">
                                        <label class="form-label">Ціль</label>
                                        <select class="form-select" @bind="newTarget">
                                            <option value="">— оберіть —</option>
                                            @foreach (var t in TargetList.Targets)
                                            {
                                                <option value="@t">@t</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Боєкомплект</label>
                                        <select class="form-select" @bind="newAmmoItemId">
                                            <option value="0">— оберіть —</option>
                                            @foreach (var a in availableAmmos)
                                            {
                                                <option value="@a.Id">@a.Name (@a.Quantity)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Результат</label>
                                        <select class="form-select" @bind="newResult">
                                            <option value="@FlightResult.Уражено">Уражено</option>
                                            <option value="@FlightResult.Знищено">Знищено</option>
                                            <option value="@FlightResult.НеУражено">Не уражено</option>
                                            <option value="@FlightResult.ВідпрацьованоВРайонЦілі">
                                                Відпрацьовано в район цілі
                                            </option>
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">К-сть цілей</label>
                                        <input type="number" class="form-control"
                                               min="1" @bind="newTargetCount" />
                                    </div>
                                </div>
                            </div>
                        }

                        @* ── БОМБЕР або КРИЛО УДАРНЕ ── *@
                        @if (selectedCrew.Type == CrewType.Бомбер || selectedCrew.Type == CrewType.КрилоУдарне)
                        {
                            var bomberList = selectedCrew.Type == CrewType.Бомбер
                                ? availableBombers
                                : availableWingsAttack;
                            var noDronesLabel = selectedCrew.Type == CrewType.Бомбер
                                ? "Немає бомберів"
                                : "Немає ударних крил";

                            <div class="row g-3 mb-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label">Безпілотник</label>
                                    @if (bomberList.Any())
                                    {
                                        <select class="form-select" @bind="newDroneItemId">
                                            <option value="0">— оберіть —</option>
                                            @foreach (var d in bomberList)
                                            {
                                                <option value="@d.Id">
                                                    @d.Name (к-сть: @d.Quantity)
                                                </option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <div class="form-control bg-light text-danger">@noDronesLabel</div>
                                    }
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Тип місії</label>
                                    <select class="form-select" @bind="newMissionType">
                                        <option value="attack">Ударна</option>
                                        <option value="delivery">Доставка</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Повернувся?</label>
                                    <select class="form-select"
                                            value="@(newDroneReturned ? "true" : "false")"
                                            @onchange='e => OnDroneReturnedChanged(e.Value?.ToString() == "true")'>
                                        <option value="true">Так</option>
                                        <option value="false">Ні (збитий)</option>
                                    </select>
                                </div>

                                @* Причина незворотності *@
                                @if (!newDroneReturned)
                                {
                                    <div class="col-md-3">
                                        <label class="form-label">Причина збиття</label>
                                        <select class="form-select"
                                                value="@newDroneNotReturnedReason"
                                                @onchange='e => OnNotReturnedReasonChanged(e.Value?.ToString() ?? "")'>
                                            <option value="">— оберіть —</option>
                                            @foreach (var r in DroneNotReturnedReasons)
                                            {
                                                <option value="@r">@r</option>
                                            }
                                        </select>
                                    </div>

                                    @if (newDroneNotReturnedReason == "Інше")
                                    {
                                        <div class="col-md-4">
                                            <label class="form-label">Вкажіть причину</label>
                                            <input class="form-control"
                                                   @bind="newDroneNotReturnedCustom"
                                                   placeholder="Опишіть причину..." />
                                        </div>
                                    }
                                }
                            </div>

                            @* Ударна місія — список скидів *@
                            @if (newMissionType == "attack")
                            {
                                <div class="border rounded p-3 mb-3 bg-light">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="fw-bold text-primary">💣 Скиди (до 4)</div>
                                        @if (newDrops.Count < 4)
                                        {
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="AddDrop">
                                                + Додати скид
                                            </button>
                                        }
                                    </div>
                                    @for (int i = 0; i < newDrops.Count; i++)
                                    {
                                        var idx = i;
                                        <div class="border rounded p-3 mb-3 bg-white">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div class="fw-bold text-muted">Скид #@(idx + 1)</div>
                                                @if (newDrops.Count > 1)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger"
                                                            @onclick="() => RemoveDrop(idx)">
                                                        ✕ Видалити
                                                    </button>
                                                }
                                            </div>
                                            <div class="row g-2 align-items-end">
                                                <div class="col-md-2">
                                                    <label class="form-label small">Час</label>
                                                    <input type="time"
                                                           class="form-control form-control-sm"
                                                           @bind="newDrops[idx].DropTime" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label small">Координати</label>
                                                    <input class="form-control form-control-sm"
                                                           @bind="newDrops[idx].Coordinates"
                                                           placeholder="36UXB 11111 11111" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small">Н.П.</label>
                                                    <input class="form-control form-control-sm"
                                                           @bind="newDrops[idx].Settlement"
                                                           placeholder="Н.П." />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small">Ціль</label>
                                                    <select class="form-select form-select-sm"
                                                            @bind="newDrops[idx].Target">
                                                        <option value="">— оберіть —</option>
                                                        @foreach (var t in TargetList.Targets)
                                                        {
                                                            <option value="@t">@t</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small">Боєкомплект</label>
                                                    <select class="form-select form-select-sm"
                                                            @bind="newDrops[idx].AmmoItemId">
                                                        <option value="0">— оберіть —</option>
                                                        @foreach (var a in availableAmmos)
                                                        {
                                                            <option value="@a.Id">@a.Name (@a.Quantity)</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small">Результат</label>
                                                    <select class="form-select form-select-sm"
                                                            @bind="newDrops[idx].Result">
                                                        <option value="@FlightResult.Уражено">Уражено</option>
                                                        <option value="@FlightResult.Знищено">Знищено</option>
                                                        <option value="@FlightResult.НеУражено">Не уражено</option>
                                                        <option value="@FlightResult.ВідпрацьованоВРайонЦілі">
                                                            Відпрацьовано в район цілі
                                                        </option>
                                                    </select>
                                                </div>
                                                <div class="col-md-1">
                                                    <label class="form-label small">К-сть цілей</label>
                                                    <input type="number"
                                                           class="form-control form-control-sm"
                                                           min="0"
                                                           @bind="newDrops[idx].TargetCount" />
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            @* Місія доставки *@
                            @if (newMissionType == "delivery")
                            {
                                <div class="border rounded p-3 mb-3 bg-light">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="fw-bold text-info">📦 Доставки</div>
                                        @if (newDrops.Count < 4)
                                        {
                                            <button class="btn btn-sm btn-outline-info"
                                                    @onclick="AddDrop">
                                                + Додати доставку
                                            </button>
                                        }
                                    </div>
                                    @for (int i = 0; i < newDrops.Count; i++)
                                    {
                                        var idx = i;
                                        <div class="border rounded p-3 mb-3 bg-white">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div class="fw-bold text-muted">Доставка #@(idx + 1)</div>
                                                @if (newDrops.Count > 1)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger"
                                                            @onclick="() => RemoveDrop(idx)">
                                                        ✕ Видалити
                                                    </button>
                                                }
                                            </div>
                                            <div class="row g-2 align-items-end">
                                                <div class="col-md-2">
                                                    <label class="form-label small">Час доставки</label>
                                                    <input type="time"
                                                           class="form-control form-control-sm"
                                                           @bind="newDrops[idx].DeliveryTime" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label small">Координати</label>
                                                    <input class="form-control form-control-sm"
                                                           @bind="newDrops[idx].Coordinates"
                                                           placeholder="36UXB 11111 11111" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label small">Населений пункт</label>
                                                    <input class="form-control form-control-sm"
                                                           @bind="newDrops[idx].Settlement"
                                                           placeholder="Н.П." />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small">Результат</label>
                                                    <select class="form-select form-select-sm"
                                                            @bind="newDrops[idx].Result">
                                                        <option value="@FlightResult.Доставлено">Доставлено</option>
                                                        <option value="@FlightResult.НеДоставлено">Не доставлено</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }

                        @* ── КРИЛО (розвідка) ── *@
                        @if (selectedCrew.Type == CrewType.Крило)
                        {
                            <div class="row g-3 mb-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label">Безпілотник</label>
                                    @if (availableWings.Any())
                                    {
                                        <select class="form-select" @bind="newDroneItemId">
                                            <option value="0">— оберіть —</option>
                                            @foreach (var d in availableWings)
                                            {
                                                <option value="@d.Id">
                                                    @d.Name (к-сть: @d.Quantity)
                                                </option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <div class="form-control bg-light text-danger">Немає крил</div>
                                    }
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Час вильоту</label>
                                    <input type="time" class="form-control" @bind="newTime" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Координати</label>
                                    <input class="form-control"
                                           @bind="newCoordinates"
                                           placeholder="36UXB 11111 11111" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Населений пункт</label>
                                    <input class="form-control"
                                           @bind="newSettlement"
                                           placeholder="Назва н.п." />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Повернувся?</label>
                                    <select class="form-select"
                                            value="@(newDroneReturned ? "true" : "false")"
                                            @onchange='e => OnDroneReturnedChanged(e.Value?.ToString() == "true")'>
                                        <option value="true">Так</option>
                                        <option value="false">Ні (збитий)</option>
                                    </select>
                                </div>

                                @if (!newDroneReturned)
                                {
                                    <div class="col-md-3">
                                        <label class="form-label">Причина збиття</label>
                                        <select class="form-select"
                                                value="@newDroneNotReturnedReason"
                                                @onchange='e => OnNotReturnedReasonChanged(e.Value?.ToString() ?? "")'>
                                            <option value="">— оберіть —</option>
                                            @foreach (var r in DroneNotReturnedReasons)
                                            {
                                                <option value="@r">@r</option>
                                            }
                                        </select>
                                    </div>

                                    @if (newDroneNotReturnedReason == "Інше")
                                    {
                                        <div class="col-md-4">
                                            <label class="form-label">Вкажіть причину</label>
                                            <input class="form-control"
                                                   @bind="newDroneNotReturnedCustom"
                                                   placeholder="Опишіть причину..." />
                                        </div>
                                    }
                                }
                            </div>
                        }

                        @* ── Повідомлення про результат додавання ── *@
                        @if (!string.IsNullOrEmpty(addFlightMessage))
                        {
                            <div class="alert @(addFlightSuccess ? "alert-success" : "alert-danger")">
                                @addFlightMessage
                            </div>
                        }

                        <button class="btn btn-primary" @onclick="AddFlight">
                            ✈ Додати виліт
                        </button>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        @* ===== МОДАЛКА РЕДАГУВАННЯ ===== *@
        @if (showEditModal)
        {
            <div class="modal d-block" style="background:rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">✏️ Редагувати виліт</h5>
                            <button class="btn-close" @onclick="CloseEditModal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label">Час</label>
                                    <input type="time" class="form-control" @bind="editTime" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Координати</label>
                                    <input class="form-control" @bind="editCoordinates" />
                                </div>

                                @if (selectedCrew.Type != CrewType.Крило)
                                {
                                    <div class="col-md-3">
                                        <label class="form-label">Ціль</label>
                                        <select class="form-select" @bind="editTarget">
                                            <option value="">— оберіть —</option>
                                            @foreach (var t in TargetList.Targets)
                                            {
                                                <option value="@t">@t</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Результат</label>
                                        <select class="form-select" @bind="editResult">
                                            <option value="@FlightResult.Уражено">Уражено</option>
                                            <option value="@FlightResult.Знищено">Знищено</option>
                                            <option value="@FlightResult.НеУражено">Не уражено</option>
                                            <option value="@FlightResult.ВідпрацьованоВРайонЦілі">
                                                Відпрацьовано в район цілі
                                            </option>
                                            <option value="@FlightResult.Доставлено">Доставлено</option>
                                            <option value="@FlightResult.НеДоставлено">Не доставлено</option>
                                        </select>
                                    </div>
                                }

                                <div class="col-md-4">
                                    <label class="form-label">Населений пункт</label>
                                    <input class="form-control" @bind="editSettlement" />
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(editFlightMessage))
                            {
                                <div class="alert @(editFlightSuccess ? "alert-success" : "alert-danger") mt-3">
                                    @editFlightMessage
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseEditModal">Скасувати</button>
                            <button class="btn btn-primary" @onclick="SaveEditFlight">Зберегти</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ===== ФІЛЬТРИ ===== *@
        <div class="d-flex flex-wrap gap-2 mb-3 align-items-end">
            @if (selectedCrew.Type != CrewType.Крило)
            {
                <div>
                    <label class="form-label mb-1 small">Результат</label>
                    <select class="form-select form-select-sm"
                            style="width:200px;"
                            @bind="filterResult"
                            @bind:after="ApplyFilter">
                        <option value="">— всі —</option>
                        <option value="Уражено">Уражено</option>
                        <option value="Знищено">Знищено</option>
                        <option value="НеУражено">Не уражено</option>
                        <option value="ВідпрацьованоВРайонЦілі">Відпрацьовано в район цілі</option>
                        <option value="Доставлено">Доставлено</option>
                        <option value="НеДоставлено">Не доставлено</option>
                    </select>
                </div>
                <div>
                    <label class="form-label mb-1 small">Ціль</label>
                    <select class="form-select form-select-sm"
                            style="width:180px;"
                            @bind="filterTarget"
                            @bind:after="ApplyFilter">
                        <option value="">— всі —</option>
                        @foreach (var t in TargetList.Targets)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
            }
            <div>
                <label class="form-label mb-1 small">Н.П.</label>
                <input class="form-control form-control-sm"
                       style="width:160px;"
                       @bind="filterSettlement"
                       @bind:after="ApplyFilter"
                       placeholder="Пошук..." />
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetFilter">
                ✕ Скинути
            </button>
        </div>

        @* ===== ТАБЛИЦЯ ВИЛЬОТІВ ===== *@
        @if (!filteredFlights.Any())
        {
            <p class="text-muted">Вильотів за цю дату немає.</p>
        }
        else
        {
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Час</th>
                        <th>Координати</th>
                        <th>Безпілотник</th>
                        @if (selectedCrew.Type != CrewType.Крило)
                        {
                            <th>Деталі вильоту</th>
                            <th>Результат</th>
                        }
                        <th>Н.П.</th>
                        <th>Додав</th>
                        <AuthorizeView Roles="SuperAdmin,Moderator">
                            <Authorized>
                                <th style="width:90px;">Дії</th>
                            </Authorized>
                        </AuthorizeView>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in pagedFlights.Select((f, i) => new { Flight = f, Index = i }))
                    {
                        var flightId = item.Flight.Id;
                        var rowNum   = (currentPage - 1) * pageSize + item.Index + 1;

                        <tr>
                            <td>@rowNum</td>

                            @* Час *@
                            <td>
                                @if (item.Flight.Drops.Any())
                                {
                                    <small>
                                        @foreach (var drop in item.Flight.Drops)
                                        {
                                            <span class="d-block">
                                                @if (drop.DeliveryTime.HasValue)
                                                { @drop.DeliveryTime.Value.ToString("HH:mm") }
                                                else
                                                { @item.Flight.Time.ToString("HH:mm") }
                                            </span>
                                        }
                                    </small>
                                }
                                else
                                { @item.Flight.Time.ToString("HH:mm") }
                            </td>

                            @* Координати *@
                            <td>
                                @if (item.Flight.Drops.Any())
                                {
                                    <small>
                                        @foreach (var drop in item.Flight.Drops)
                                        {
                                            <span class="d-block">@drop.Coordinates</span>
                                        }
                                    </small>
                                }
                                else
                                { @item.Flight.Coordinates }
                            </td>

                            @* Безпілотник *@
                            <td>
                                @if (item.Flight.DroneItem != null)
                                { @item.Flight.DroneItem.Name }
                                else
                                { <span class="text-muted small">—</span> }
                            </td>

                            @* Деталі та результат — тільки не-Крило *@
                            @if (selectedCrew.Type != CrewType.Крило)
                            {
                                <td>
                                    @if (!item.Flight.Drops.Any())
                                    {
                                        <small><span class="d-block">@item.Flight.Target</span></small>
                                    }
                                    else if (item.Flight.Drops.All(d => d.IsDelivery))
                                    {
                                        <small>
                                            @foreach (var drop in item.Flight.Drops)
                                            {
                                                <span class="d-block">
                                                    📦
                                                    @if (drop.DeliveryTime.HasValue)
                                                    {
                                                        <span>@drop.DeliveryTime.Value.ToString("HH:mm")</span>
                                                        <span class="text-muted"> — </span>
                                                    }
                                                    <span class="badge @GetResultBadge(drop.Result)"
                                                          style="font-size:0.65rem;">
                                                        @GetResultLabel(drop.Result)
                                                    </span>
                                                    @if (!string.IsNullOrEmpty(drop.Settlement))
                                                    {
                                                        <span class="text-muted"> [@drop.Settlement]</span>
                                                    }
                                                </span>
                                            }
                                        </small>
                                    }
                                    else
                                    {
                                        <small>
                                            @foreach (var drop in item.Flight.Drops)
                                            {
                                                <span class="d-block">
                                                    @if (!string.IsNullOrEmpty(drop.Target))
                                                    {
                                                        <span>@drop.Target</span>
                                                        <span class="text-muted"> — </span>
                                                    }
                                                    <span>@drop.AmmoItem?.Name</span>
                                                    @if (drop.TargetCount > 0)
                                                    {
                                                        <span class="text-muted"> (@drop.TargetCount шт.)</span>
                                                    }
                                                </span>
                                            }
                                        </small>
                                    }
                                </td>

                                <td>
                                    @if (item.Flight.Drops.All(d => d.IsDelivery) && item.Flight.Drops.Any())
                                    {
                                        @* результат вже відображено в деталях *@
                                    }
                                    else if (item.Flight.Drops.Any())
                                    {
                                        <small>
                                            @foreach (var drop in item.Flight.Drops)
                                            {
                                                <span class="d-block">
                                                    <span class="badge @GetResultBadge(drop.Result)"
                                                          style="font-size:0.75rem;">
                                                        @GetResultLabel(drop.Result)
                                                    </span>
                                                </span>
                                            }
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="badge @GetResultBadge(item.Flight.Result)">
                                            @GetResultLabel(item.Flight.Result)
                                        </span>
                                    }

                                    @* Бейдж повернення для Бомбера / КрилоУдарне *@
                                    @if (selectedCrew.Type == CrewType.Бомбер || selectedCrew.Type == CrewType.КрилоУдарне)
                                    {
                                        <div class="mt-1">
                                            @if (item.Flight.DroneReturned)
                                            {
                                                <span class="badge bg-success" style="font-size:0.65rem;">
                                                    ↩ повернувся
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger" style="font-size:0.65rem;">
                                                    ✖ збитий
                                                </span>
                                                @if (!string.IsNullOrEmpty(item.Flight.DroneNotReturnedReason))
                                                {
                                                    <div class="text-muted" style="font-size:0.7rem;">
                                                        @(item.Flight.DroneNotReturnedReason == "Інше" && !string.IsNullOrEmpty(item.Flight.DroneNotReturnedCustom)
                                                            ? item.Flight.DroneNotReturnedCustom
                                                            : item.Flight.DroneNotReturnedReason)
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                </td>
                            }

                            @* Н.П. *@
                            <td>
                                @if (item.Flight.Drops.Any())
                                {
                                    <small>
                                        @foreach (var drop in item.Flight.Drops)
                                        {
                                            <span class="d-block">@drop.Settlement</span>
                                        }
                                    </small>
                                }
                                else
                                { @item.Flight.Settlement }
                            </td>

                            <td class="text-muted small">@item.Flight.CreatedBy</td>

                            <AuthorizeView Roles="SuperAdmin,Moderator">
                                <Authorized>
                                    <td>
                                        <button class="btn btn-xs btn-warning me-1"
                                                @onclick="() => OpenEditModal(item.Flight)">
                                            ✎
                                        </button>
                                        <button class="btn btn-xs btn-danger"
                                                @onclick="() => DeleteFlight(flightId)">
                                            🗑
                                        </button>
                                    </td>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <nav>
                    <ul class="pagination">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="PrevPage">&#8249;</button>
                        </li>
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            var pn = p;
                            <li class="page-item @(currentPage == pn ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(pn)">@pn</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="NextPage">&#8250;</button>
                        </li>
                    </ul>
                </nav>
                <p class="text-muted small">
                    Показано @pagedFlights.Count() з @filteredFlights.Count.
                    Сторінка @currentPage з @totalPages.
                </p>
            }
        }
    }
}

<style>
    .btn-xs { padding: 0.1rem 0.4rem; font-size: 0.75rem; }
</style>

@code {
    // ── Поточний користувач ─────────────────────────────────────────────────
    private string currentUser = "";

    // ── Роти та екіпажі ─────────────────────────────────────────────────────
    private List<Company>? companies;
    private int             selectedCompanyId;
    private List<Crew>?     crews;
    private int             selectedCrewId;
    private Crew?           selectedCrew;

    // ── Дата та доступні запаси ──────────────────────────────────────────────
    private DateOnly        selectedDate        = DateOnly.FromDateTime(DateTime.Today);
    private List<DroneItem> availableDrones     = new();
    private List<DroneItem> availableBombers    = new();
    private List<DroneItem> availableWings      = new();
    private List<DroneItem> availableWingsAttack = new();
    private List<AmmoItem>  availableAmmos      = new();

    // ── Причини незворотності ────────────────────────────────────────────────
    private static readonly List<string> DroneNotReturnedReasons = new()
    {
        "Подавлення РЕБ",
        "Збито стрілецькою зброєю",
        "Збито FPV дроном",
        "Збито з ПЗРК",
        "Збито з ЗСУ",
        "Відмова двигуна",
        "Відмова системи управління",
        "Помилка пілота",
        "Збій навігації / GPS",
        "Погодні умови",
        "Інше"
    };

    // ── Форма FPV ────────────────────────────────────────────────────────────
    private TimeOnly     newTime        = TimeOnly.FromDateTime(DateTime.Now);
    private string       newCoordinates = "";
    private string       newTarget      = "";
    private int          newDroneItemId = 0;
    private int          newAmmoItemId  = 0;
    private int          newTargetCount = 1;
    private FlightResult newResult      = FlightResult.Уражено;
    private string       newSettlement  = "";
    private string       addFlightMessage = "";
    private bool         addFlightSuccess = false;

    // ── Форма Бомбер / Крило / КрилоУдарне ──────────────────────────────────
    private string          newMissionType           = "attack";
    private bool            newDroneReturned         = true;
    private string          newDroneNotReturnedReason = "";
    private string          newDroneNotReturnedCustom = "";
    private List<DropModel> newDrops                 = new() { new DropModel() };

    // ── Редагування вильоту ──────────────────────────────────────────────────
    private bool         showEditModal    = false;
    private int          editingFlightId  = 0;
    private TimeOnly     editTime;
    private string       editCoordinates  = "";
    private string       editTarget       = "";
    private FlightResult editResult;
    private string       editSettlement   = "";
    private string       editFlightMessage = "";
    private bool         editFlightSuccess = false;

    // ── Список вильотів та фільтри ───────────────────────────────────────────
    private List<Flight>        allFlights      = new();
    private List<Flight>        filteredFlights = new();
    private IEnumerable<Flight> pagedFlights    = new List<Flight>();

    private string filterResult     = "";
    private string filterSettlement = "";
    private string filterTarget     = "";

    // ── Пагінація ────────────────────────────────────────────────────────────
    private int currentPage = 1;
    private int pageSize    = 15;
    private int totalPages  => (int)Math.Ceiling(filteredFlights.Count / (double)pageSize);

    // ── Локальна модель форми скиду ──────────────────────────────────────────
    private class DropModel
    {
        public string       Coordinates  { get; set; } = "";
        public string       Target       { get; set; } = "";
        public string       Settlement   { get; set; } = "";
        public int          AmmoItemId   { get; set; } = 0;
        public FlightResult Result       { get; set; } = FlightResult.Уражено;
        public int          TargetCount  { get; set; } = 0;
        public TimeOnly     DropTime     { get; set; } = TimeOnly.FromDateTime(DateTime.Now);
        public TimeOnly     DeliveryTime { get; set; } = TimeOnly.FromDateTime(DateTime.Now);
    }

    // ════════════════════════════════════════════════════════════════════════
    // ІНІЦІАЛІЗАЦІЯ
    // ════════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = authState.User.Identity?.Name ?? "";

        companies = await WarehouseService.GetCompaniesAsync();

        if (companies.Any())
        {
            selectedCompanyId = companies.First().Id;
            await LoadCrews();
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // ВИБІР РОТИ / ЕКІПАЖУ
    // ════════════════════════════════════════════════════════════════════════
    private async Task SelectCompany(int id)
    {
        selectedCompanyId = id;
        selectedCrewId    = 0;
        selectedCrew      = null;
        await LoadCrews();
    }

    private async Task LoadCrews()
    {
        crews = await CrewService.GetCrewsAsync(selectedCompanyId);

        if (crews.Any())
        {
            selectedCrewId = crews.First().Id;
            selectedCrew   = crews.First();
            await LoadCrewData();
        }
        else
        {
            selectedCrew        = null;
            availableBombers    = new();
            availableWings      = new();
            availableWingsAttack = new();
        }
    }

    private async Task SelectCrew(int id)
    {
        selectedCrewId = id;
        selectedCrew   = crews?.FirstOrDefault(c => c.Id == id);

        currentPage      = 1;
        filterResult     = "";
        filterSettlement = "";
        filterTarget     = "";

        await LoadCrewData();
        ResetForm();
    }

    private async Task LoadCrewData()
    {
        availableDrones      = await FlightService.GetAvailableDronesAsync(selectedCrewId);
        availableBombers     = await FlightService.GetAvailableBombersAsync(selectedCrewId);
        availableWings       = await FlightService.GetAvailableWingsAsync(selectedCrewId);
        availableWingsAttack = await FlightService.GetAvailableWingsAttackAsync(selectedCrewId);
        availableAmmos       = await FlightService.GetAvailableAmmosAsync(selectedCrewId);

        if (selectedCrew?.Type == CrewType.Бомбер && availableBombers.Any())
            newDroneItemId = availableBombers.First().Id;
        else if (selectedCrew?.Type == CrewType.Крило && availableWings.Any())
            newDroneItemId = availableWings.First().Id;
        else if (selectedCrew?.Type == CrewType.КрилоУдарне && availableWingsAttack.Any())
            newDroneItemId = availableWingsAttack.First().Id;

        await LoadFlights();
    }

    // ════════════════════════════════════════════════════════════════════════
    // ВИЛЬОТИ — ЗАВАНТАЖЕННЯ ТА ФІЛЬТРАЦІЯ
    // ════════════════════════════════════════════════════════════════════════
    private async Task LoadFlights()
    {
        allFlights = await FlightService.GetFlightsAsync(selectedCrewId, selectedDate);
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        filteredFlights = allFlights.Where(f =>
        {
            if (!string.IsNullOrEmpty(filterResult) &&
                f.Result.ToString() != filterResult)
                return false;

            if (!string.IsNullOrEmpty(filterSettlement) &&
                !f.Settlement.Contains(filterSettlement, StringComparison.OrdinalIgnoreCase))
                return false;

            if (!string.IsNullOrEmpty(filterTarget))
            {
                var targets = f.Drops.Any()
                    ? f.Drops.Select(d => d.Target).ToList()
                    : new List<string> { f.Target };

                if (!targets.Any(t => t == filterTarget))
                    return false;
            }

            return true;
        }).ToList();

        currentPage = 1;
        UpdatePagedFlights();
    }

    private void ResetFilter()
    {
        filterResult = ""; filterSettlement = ""; filterTarget = "";
        ApplyFilter();
    }

    private void UpdatePagedFlights()
    {
        pagedFlights = filteredFlights
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize);
    }

    // ════════════════════════════════════════════════════════════════════════
    // ФОРМА — УПРАВЛІННЯ СКИДАМИ ТА ПРИЧИНОЮ ЗБИТТЯ
    // ════════════════════════════════════════════════════════════════════════
    private void AddDrop()
    {
        if (newDrops.Count < 4)
            newDrops.Add(new DropModel());
    }

    private void RemoveDrop(int idx)
    {
        if (newDrops.Count > 1)
            newDrops.RemoveAt(idx);
    }

    private void OnDroneReturnedChanged(bool returned)
    {
        newDroneReturned = returned;
        if (returned)
        {
            newDroneNotReturnedReason = "";
            newDroneNotReturnedCustom = "";
        }
    }

    private void OnNotReturnedReasonChanged(string reason)
    {
        newDroneNotReturnedReason = reason;
        if (reason != "Інше")
            newDroneNotReturnedCustom = "";
    }

    private void ResetForm()
    {
        newCoordinates           = "";
        newTarget                = "";
        newAmmoItemId            = 0;
        newTargetCount           = 1;
        newResult                = FlightResult.Уражено;
        newSettlement            = "";
        newMissionType           = "attack";
        newDroneReturned         = true;
        newDroneNotReturnedReason = "";
        newDroneNotReturnedCustom = "";
        newDrops                 = new() { new DropModel() };
        newTime                  = TimeOnly.FromDateTime(DateTime.Now);
        addFlightMessage         = "";

        newDroneItemId = selectedCrew?.Type switch
        {
            CrewType.Бомбер      => availableBombers.FirstOrDefault()?.Id    ?? 0,
            CrewType.Крило       => availableWings.FirstOrDefault()?.Id       ?? 0,
            CrewType.КрилоУдарне => availableWingsAttack.FirstOrDefault()?.Id ?? 0,
            _                    => 0
        };
    }

    private static string Clean(string? v) =>
        string.IsNullOrWhiteSpace(v) ? "" : v.Trim();

    // ════════════════════════════════════════════════════════════════════════
    // ДОДАВАННЯ ВИЛЬОТУ
    // ════════════════════════════════════════════════════════════════════════
    private async Task AddFlight()
    {
        addFlightMessage = "";

        try
        {
            if (selectedCrew == null) return;

            if (selectedCrew.Type == CrewType.FPV)
            {
                if (newDroneItemId == 0) throw new Exception("Оберіть безпілотник.");
                if (newAmmoItemId == 0)  throw new Exception("Оберіть боєкомплект.");
                if (string.IsNullOrWhiteSpace(newSettlement))
                    throw new Exception("Введіть населений пункт.");

                await FlightService.AddFpvFlightAsync(new FpvFlightRequest
                {
                    CrewId      = selectedCrewId,
                    Date        = selectedDate,
                    Time        = newTime,
                    Coordinates = Clean(newCoordinates),
                    Target      = Clean(newTarget),
                    Settlement  = Clean(newSettlement),
                    DroneItemId = newDroneItemId,
                    AmmoItemId  = newAmmoItemId,
                    Result      = newResult,
                    TargetCount = newTargetCount,
                    CreatedBy   = currentUser
                });
            }
            else if (selectedCrew.Type == CrewType.Бомбер)
            {
                if (newDroneItemId == 0) throw new Exception("Оберіть безпілотник.");

                await FlightService.AddBomberFlightAsync(new BomberFlightRequest
                {
                    CrewId                = selectedCrewId,
                    Date                  = selectedDate,
                    Time                  = newTime,
                    DroneItemId           = newDroneItemId,
                    DroneReturned         = newDroneReturned,
                    DroneNotReturnedReason = newDroneReturned ? null : Clean(newDroneNotReturnedReason),
                    DroneNotReturnedCustom = newDroneReturned ? null : Clean(newDroneNotReturnedCustom),
                    MissionType           = newMissionType,
                    CreatedBy             = currentUser,
                    Drops                 = newDrops.Select(d => new DropRequest
                    {
                        Coordinates  = Clean(d.Coordinates),
                        Target       = Clean(d.Target),
                        Settlement   = Clean(d.Settlement),
                        AmmoItemId   = d.AmmoItemId,
                        Result       = d.Result,
                        TargetCount  = d.TargetCount,
                        DropTime     = d.DropTime,
                        DeliveryTime = d.DeliveryTime,
                        IsDelivery   = newMissionType == "delivery"
                    }).ToList()
                });
            }
            else if (selectedCrew.Type == CrewType.КрилоУдарне)
            {
                if (newDroneItemId == 0) throw new Exception("Оберіть безпілотник.");

                await FlightService.AddWingAttackFlightAsync(new BomberFlightRequest
                {
                    CrewId                = selectedCrewId,
                    Date                  = selectedDate,
                    Time                  = newTime,
                    DroneItemId           = newDroneItemId,
                    DroneReturned         = newDroneReturned,
                    DroneNotReturnedReason = newDroneReturned ? null : Clean(newDroneNotReturnedReason),
                    DroneNotReturnedCustom = newDroneReturned ? null : Clean(newDroneNotReturnedCustom),
                    MissionType           = newMissionType,
                    CreatedBy             = currentUser,
                    Drops                 = newDrops.Select(d => new DropRequest
                    {
                        Coordinates  = Clean(d.Coordinates),
                        Target       = Clean(d.Target),
                        Settlement   = Clean(d.Settlement),
                        AmmoItemId   = d.AmmoItemId,
                        Result       = d.Result,
                        TargetCount  = d.TargetCount,
                        DropTime     = d.DropTime,
                        DeliveryTime = d.DeliveryTime,
                        IsDelivery   = newMissionType == "delivery"
                    }).ToList()
                });
            }
            else if (selectedCrew.Type == CrewType.Крило)
            {
                if (newDroneItemId == 0) throw new Exception("Оберіть безпілотник.");

                await FlightService.AddWingFlightAsync(new WingFlightRequest
                {
                    CrewId                = selectedCrewId,
                    Date                  = selectedDate,
                    Time                  = newTime,
                    Coordinates           = Clean(newCoordinates),
                    Settlement            = Clean(newSettlement),
                    DroneItemId           = newDroneItemId,
                    DroneReturned         = newDroneReturned,
                    DroneNotReturnedReason = newDroneReturned ? null : Clean(newDroneNotReturnedReason),
                    DroneNotReturnedCustom = newDroneReturned ? null : Clean(newDroneNotReturnedCustom),
                    CreatedBy             = currentUser
                });
            }

            addFlightMessage = "Виліт додано.";
            addFlightSuccess = true;

            await LoadCrewData();
            ResetForm();
        }
        catch (Exception ex)
        {
            addFlightMessage = ex.Message;
            addFlightSuccess = false;
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // РЕДАГУВАННЯ ВИЛЬОТУ
    // ════════════════════════════════════════════════════════════════════════
    private void OpenEditModal(Flight flight)
    {
        editingFlightId   = flight.Id;
        editCoordinates   = flight.Coordinates;
        editTarget        = flight.Target;
        editTime          = flight.Time;
        editResult        = flight.Result;
        editSettlement    = flight.Settlement;
        editFlightMessage = "";
        editFlightSuccess = false;
        showEditModal     = true;
    }

    private void CloseEditModal()
    {
        showEditModal     = false;
        editingFlightId   = 0;
        editFlightMessage = "";
    }

    private async Task SaveEditFlight()
    {
        editFlightMessage = "";
        try
        {
            await FlightService.UpdateFlightAsync(
                editingFlightId, editTime,
                editCoordinates, editTarget,
                editResult, editSettlement);

            editFlightMessage = "Збережено.";
            editFlightSuccess = true;
            await LoadFlights();
        }
        catch (Exception ex)
        {
            editFlightMessage = ex.Message;
            editFlightSuccess = false;
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // ВИДАЛЕННЯ ВИЛЬОТУ
    // ════════════════════════════════════════════════════════════════════════
    private async Task DeleteFlight(int flightId)
    {
        if (selectedCrew == null) return;
        await FlightService.DeleteFlightAsync(flightId, selectedCrew.Type);
        await LoadCrewData();
        ResetForm();
    }

    // ════════════════════════════════════════════════════════════════════════
    // ПАГІНАЦІЯ
    // ════════════════════════════════════════════════════════════════════════
    private void GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages) { currentPage = page; UpdatePagedFlights(); }
    }

    private void PrevPage() => GoToPage(currentPage - 1);
    private void NextPage() => GoToPage(currentPage + 1);

    // ════════════════════════════════════════════════════════════════════════
    // ДОПОМІЖНІ МЕТОДИ
    // ════════════════════════════════════════════════════════════════════════
    private string GetResultLabel(FlightResult result) => result switch
    {
        FlightResult.Уражено                 => "Уражено",
        FlightResult.Знищено                 => "Знищено",
        FlightResult.НеУражено               => "Не уражено",
        FlightResult.ВідпрацьованоВРайонЦілі => "Відпрацьовано в район цілі",
        FlightResult.Доставлено              => "Доставлено",
        FlightResult.НеДоставлено            => "Не доставлено",
        _                                    => ""
    };

    private string GetResultBadge(FlightResult result) => result switch
    {
        FlightResult.Уражено                 => "bg-warning text-dark",
        FlightResult.Знищено                 => "bg-success",
        FlightResult.НеУражено               => "bg-danger",
        FlightResult.ВідпрацьованоВРайонЦілі => "bg-secondary",
        FlightResult.Доставлено              => "bg-info text-dark",
        FlightResult.НеДоставлено            => "bg-dark",
        _                                    => "bg-light"
    };

    private string GetCrewTypeBadge(CrewType type) => type switch
    {
        CrewType.FPV         => "bg-danger",
        CrewType.Бомбер      => "bg-primary",
        CrewType.Крило       => "bg-success",
        CrewType.КрилоУдарне => "bg-warning text-dark",
        _                    => "bg-secondary"
    };
}
